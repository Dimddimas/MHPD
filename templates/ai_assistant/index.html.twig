{% extends 'base.html.twig' %}

{% block title %}Radar Estratégico{% endblock %}
{% block page_title %}Radar Estratégico{% endblock %}
{% block page_subtitle %}Analista de inteligência de mercado com IA · dados reais · decisão imediata{% endblock %}

{% block topbar_actions %}
<button onclick="clearChat()" style="display:flex;align-items:center;gap:5px;background:transparent;border:1px solid var(--border);color:var(--text-muted);border-radius:8px;padding:5px 12px;font-size:11.5px;cursor:pointer;font-family:'DM Sans',sans-serif;transition:all .15s" onmouseover="this.style.borderColor='#ef4444';this.style.color='#ef4444'" onmouseout="this.style.borderColor='var(--border)';this.style.color='var(--text-muted)'">
    <i class="bi bi-arrow-counterclockwise"></i> Nova sessão
</button>
{% endblock %}

{% block extra_css %}
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@600;700;800&family=DM+Sans:ital,wght@0,300;0,400;0,500;0,600;0,700;1,400&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
/* ─── ROOT ──────────────────────────────────────────── */
.radar-root {
    display: flex;
    flex-direction: column;
    gap: 10px;
}

/* ─── INPUT STRIP ───────────────────────────────────── */
.input-strip {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow);
}
.input-main {
    display: flex;
    align-items: flex-end;
    gap: 10px;
    padding: 14px 16px 12px;
}
.radar-textarea {
    flex: 1; resize: none; border: none; outline: none;
    background: transparent;
    font-family: 'DM Sans', sans-serif;
    font-size: 15px; font-weight: 400;
    color: var(--text-primary);
    min-height: 26px; max-height: 100px;
    line-height: 1.5; padding: 0;
}
.radar-textarea::placeholder { color: var(--text-muted); }

.btn-fire {
    display: flex; align-items: center; gap: 7px;
    background: var(--brand); color: #fff;
    border: none; border-radius: 9px;
    padding: 9px 22px;
    font-size: 13px; font-weight: 600;
    cursor: pointer; transition: all .15s;
    font-family: 'DM Sans', sans-serif;
    white-space: nowrap; flex-shrink: 0;
    letter-spacing: .01em;
}
.btn-fire:hover   { background: var(--brand-dark); box-shadow: 0 4px 14px rgba(37,99,235,.25); }
.btn-fire:disabled{ background: var(--border-2); cursor: not-allowed; box-shadow: none; }

.examples-row {
    display: flex; align-items: center; gap: 6px;
    padding: 0 16px 12px;
    border-top: 1px solid var(--border);
    padding-top: 10px;
    flex-wrap: wrap;
}
.ex-label {
    font-size: 10.5px; font-weight: 600; text-transform: uppercase;
    letter-spacing: .07em; color: var(--text-muted); flex-shrink: 0;
}
.ex-chip {
    display: inline-flex; align-items: center;
    border: 1px solid var(--border);
    background: transparent; color: var(--text-secondary);
    border-radius: 6px; padding: 4px 10px;
    font-size: 11.5px; font-weight: 400;
    cursor: pointer; transition: all .12s;
    font-family: 'DM Sans', sans-serif; white-space: nowrap;
}
.ex-chip:hover { border-color: var(--brand); color: var(--brand); background: var(--brand-light); }

/* ─── MAIN GRID ─────────────────────────────────────── */
.radar-grid {
    display: grid;
    grid-template-columns: 1fr 288px;
    gap: 10px;
    align-items: start;
}
@media (max-width: 1050px) { .radar-grid { grid-template-columns: 1fr; } }

/* ─── CENTER ────────────────────────────────────────── */
.center-col { display: flex; flex-direction: column; gap: 8px; }

/* Status */
.status-row {
    display: flex; align-items: center; gap: 7px;
    font-size: 11px; color: var(--text-muted);
    padding: 0 2px;
}
.s-dot {
    width: 7px; height: 7px; border-radius: 50%;
    background: #22c55e; flex-shrink: 0; transition: background .3s;
}
.s-dot.busy { background: var(--brand); animation: pulse 1s ease-in-out infinite; }
@keyframes pulse { 0%,100%{opacity:1} 50%{opacity:.3} }

/* Empty state */
.exec-empty {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow);
    padding: 60px 24px;
    display: flex; flex-direction: column;
    align-items: center; justify-content: center;
    text-align: center;
    position: relative; overflow: hidden;
}
.exec-empty::before {
    content: '';
    position: absolute; inset: 0;
    background: radial-gradient(ellipse at 50% -10%, rgba(37,99,235,.05) 0%, transparent 65%);
    pointer-events: none;
}
.empty-pulse-ring {
    position: relative;
    width: 60px; height: 60px;
    display: flex; align-items: center; justify-content: center;
    margin-bottom: 18px;
}
.empty-pulse-ring::before,
.empty-pulse-ring::after {
    content: '';
    position: absolute; border-radius: 50%;
    border: 1.5px solid var(--brand);
    animation: ringPulse 2.4s ease-out infinite;
}
.empty-pulse-ring::before { width: 60px; height: 60px; animation-delay: 0s; }
.empty-pulse-ring::after  { width: 60px; height: 60px; animation-delay: .8s; }
@keyframes ringPulse {
    0%   { transform: scale(.7); opacity: .7; }
    100% { transform: scale(1.7); opacity: 0; }
}
.empty-icon-inner {
    width: 44px; height: 44px;
    background: var(--brand-light);
    border-radius: 14px;
    display: flex; align-items: center; justify-content: center;
    color: var(--brand); font-size: 20px;
    z-index: 1;
}
.empty-title {
    font-family: 'Syne', sans-serif;
    font-size: 20px; font-weight: 700;
    color: var(--text-primary);
    margin-bottom: 6px;
    letter-spacing: -.01em;
}
.empty-sub {
    font-size: 13px; color: var(--text-muted);
    line-height: 1.6; max-width: 340px;
}
.empty-tags {
    display: flex; gap: 6px; flex-wrap: wrap;
    justify-content: center; margin-top: 16px;
}
.empty-tag {
    font-size: 11px; font-weight: 500;
    background: var(--surface-2); color: var(--text-muted);
    border-radius: 6px; padding: 3px 10px;
    border: 1px solid var(--border);
}

/* Loading */
.exec-loading {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow);
    padding: 60px 24px;
    display: flex; flex-direction: column;
    align-items: center; gap: 12px;
}
.load-bar {
    width: 180px; height: 2px;
    background: var(--border); border-radius: 2px; overflow: hidden;
}
.load-bar::after {
    content: ''; display: block; height: 100%; width: 35%;
    background: var(--brand); border-radius: 2px;
    animation: sweep 1.1s ease-in-out infinite;
}
@keyframes sweep { 0%{transform:translateX(-100%)} 100%{transform:translateX(390%)} }
.load-lbl { font-size: 12px; color: var(--text-muted); }

/* Cards 2×2 */
.exec-cards {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 8px;
}
@media(max-width:700px){ .exec-cards{grid-template-columns:1fr;} }

.ec {
    border-radius: var(--radius-lg);
    padding: 16px;
    display: flex; flex-direction: column; gap: 10px;
    border: 1px solid transparent;
    animation: cardIn .35s cubic-bezier(.34,1.56,.64,1) both;
}
.ec:nth-child(1){ animation-delay:.04s }
.ec:nth-child(2){ animation-delay:.10s }
.ec:nth-child(3){ animation-delay:.16s }
.ec:nth-child(4){ animation-delay:.22s }
@keyframes cardIn {
    from { opacity:0; transform: translateY(8px) scale(.98); }
    to   { opacity:1; transform: none; }
}

.ec-diag  { background:#EFF6FF; border-color:#BFDBFE; }
.ec-evid  { background:#F0FDF4; border-color:#BBF7D0; }
.ec-risk  { background:#FFFBEB; border-color:#FDE68A; }
.ec-recom { background:#FDF4FF; border-color:#E9D5FF; }

.ec-head {
    display: flex; align-items: center; gap: 8px;
}
.ec-ico {
    width: 26px; height: 26px; border-radius: 8px;
    display: flex; align-items: center; justify-content: center;
    font-size: 13px; flex-shrink: 0;
}
.ec-diag  .ec-ico { background:#BFDBFE; color:#1D4ED8; }
.ec-evid  .ec-ico { background:#BBF7D0; color:#15803D; }
.ec-risk  .ec-ico { background:#FDE68A; color:#92400E; }
.ec-recom .ec-ico { background:#E9D5FF; color:#7C3AED; }

.ec-lbl {
    font-size: 10px; font-weight: 700;
    text-transform: uppercase; letter-spacing: .09em;
}
.ec-diag  .ec-lbl { color:#1E40AF; }
.ec-evid  .ec-lbl { color:#166534; }
.ec-risk  .ec-lbl { color:#92400E; }
.ec-recom .ec-lbl { color:#6B21A8; }

.ec-body {
    font-size: 12.5px; line-height: 1.65; color: var(--text-secondary);
}
.ec-body p { margin: 3px 0; }
.ec-body p:first-child { margin-top: 0; }
.ec-body p:last-child  { margin-bottom: 0; }
.ec-body ul, .ec-body ol { padding-left: 14px; margin: 4px 0; }
.ec-body strong { color: var(--text-primary); font-weight: 600; }
.ec-body code { font-family:'DM Mono',monospace; font-size:11px; background:rgba(0,0,0,.06); padding:1px 5px; border-radius:4px; }

/* KV table para evidência */
.kv { width:100%; border-collapse:collapse; }
.kv tr { border-bottom: 1px solid rgba(0,0,0,.06); }
.kv tr:last-child { border-bottom: none; }
.kv td { padding: 4px 2px; font-size: 12px; vertical-align: top; }
.kv td:first-child { color: var(--text-muted); padding-right: 8px; line-height: 1.4; }
.kv td:last-child  { font-family:'DM Mono',monospace; font-weight:600; color:#166534; text-align:right; font-size:11.5px; white-space:nowrap; }

/* ─── HISTÓRICO ──────────────────────────────────────── */
.hist-panel {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow);
    display: flex; flex-direction: column;
    max-height: 260px; overflow: hidden;
}
.hist-hd {
    padding: 8px 14px;
    border-bottom: 1px solid var(--border);
    display: flex; align-items: center; gap: 7px;
    flex-shrink: 0;
}
.hist-hd-t {
    font-size: 10px; font-weight: 700;
    text-transform: uppercase; letter-spacing: .07em;
    color: var(--text-muted);
}
.hist-badge {
    background: var(--brand); color: #fff;
    border-radius: 10px; padding: 1px 7px;
    font-size: 10px; font-weight: 700;
    margin-left: auto;
}
.hist-msgs {
    flex: 1; overflow-y: auto;
    padding: 8px 12px; display: flex;
    flex-direction: column; gap: 8px;
}
.hist-footer {
    border-top: 1px solid var(--border);
    padding: 7px 10px;
    display: flex; gap: 6px; align-items: flex-end;
    background: var(--surface); flex-shrink: 0;
}
.hist-input {
    flex:1; resize:none; border:1px solid var(--border-2);
    border-radius:7px; padding:6px 9px;
    font-family:'DM Sans',sans-serif;
    font-size:12px; color:var(--text-primary); background:var(--bg);
    outline:none; min-height:30px; max-height:70px; line-height:1.5;
    transition:border-color .15s;
}
.hist-input:focus { border-color:var(--brand); }
.hist-send {
    width:30px; height:30px; background:var(--brand); color:#fff;
    border:none; border-radius:7px; cursor:pointer; flex-shrink:0;
    display:flex; align-items:center; justify-content:center; font-size:12px;
    transition:background .12s;
}
.hist-send:hover { background:var(--brand-dark); }
.hist-send:disabled { background:var(--border-2); cursor:not-allowed; }

/* mensagens */
.msg-r { display:flex; gap:7px; animation:msgIn .18s ease; }
.msg-r.user { flex-direction:row-reverse; }
@keyframes msgIn { from{opacity:0;transform:translateY(3px)} to{opacity:1;transform:none} }
.msg-av {
    width:24px; height:24px; border-radius:50%;
    display:flex; align-items:center; justify-content:center;
    font-size:11px; flex-shrink:0; margin-top:1px;
}
.msg-av.ai   { background:var(--brand-light); color:var(--brand); }
.msg-av.user { background:var(--surface-2);   color:var(--text-secondary); }
.msg-b {
    max-width:86%; padding:7px 10px; border-radius:8px;
    font-size:12px; line-height:1.55;
}
.msg-b.ai   { background:var(--surface-2); color:var(--text-primary); border-radius:2px 8px 8px 8px; }
.msg-b.user { background:var(--brand); color:#fff; border-radius:8px 2px 8px 8px; }
.msg-b.ai p { margin:2px 0; }
.msg-b.ai strong { color:var(--text-primary); }
.msg-b.ai ul { padding-left:12px; margin:2px 0; }
.msg-meta { font-size:9.5px; color:var(--text-muted); margin-top:2px; }
.msg-r.user .msg-meta { text-align:right; }
.tool-t {
    display:inline-flex; align-items:center; gap:2px;
    font-size:9.5px; background:var(--brand-light); color:var(--brand);
    padding:1px 5px; border-radius:5px; margin-right:2px;
}
.typing { display:flex; gap:3px; align-items:center; padding:2px 0; }
.td { width:5px; height:5px; border-radius:50%; background:var(--brand); opacity:.4; animation:blink 1.2s infinite; }
.td:nth-child(2){animation-delay:.2s}.td:nth-child(3){animation-delay:.4s}
@keyframes blink{0%,80%,100%{opacity:.4}40%{opacity:1}}

/* ─── SIDEBAR ────────────────────────────────────────── */
.sidebar-col { display:flex; flex-direction:column; gap:8px; }
.side-card {
    background:var(--surface);
    border:1px solid var(--border);
    border-radius:var(--radius-lg);
    box-shadow:var(--shadow);
    overflow:hidden;
}
.side-hd {
    padding:9px 12px;
    display:flex; align-items:center; justify-content:space-between;
    cursor:pointer; user-select:none;
    border-bottom:1px solid transparent;
    transition:border-color .15s;
}
.side-hd.open { border-bottom-color:var(--border); }
.side-hd-t {
    font-size:10px; font-weight:700; text-transform:uppercase;
    letter-spacing:.07em; color:var(--text-secondary);
    display:flex; align-items:center; gap:6px;
}
.side-hd-t i { color:var(--brand); font-size:12px; }
.side-chev { font-size:11px; color:var(--text-muted); transition:transform .2s; }
.side-hd:not(.open) .side-chev { transform:rotate(-90deg); }
.side-body { padding:10px 12px; }
.side-body.closed { display:none; }

/* calc rows */
.calc-r { display:flex; justify-content:space-between; align-items:center; padding:5px 0; border-bottom:1px solid var(--surface-2); font-size:12px; }
.calc-r:last-child { border-bottom:none; }
.calc-lbl { color:var(--text-muted); }
.calc-val { font-family:'DM Mono',monospace; font-weight:600; color:var(--text-primary); font-size:11px; }
.qpre {
    background:#0d1117; border:1px solid rgba(99,120,200,.2);
    border-radius:7px; padding:9px 11px;
    font-family:'DM Mono',monospace; font-size:10.5px;
    color:#93c5fd; line-height:1.65; margin-top:8px;
    white-space:pre-wrap; word-break:break-all;
}

/* fonte rows */
.src-r { display:flex; align-items:center; gap:8px; padding:5px 0; border-bottom:1px solid var(--surface-2); font-size:11.5px; color:var(--text-secondary); }
.src-r:last-child { border-bottom:none; }
.src-dot { width:5px; height:5px; border-radius:50%; background:var(--brand); flex-shrink:0; }

/* sugestões */
.sug-b {
    display:block; width:100%; background:transparent;
    border:1px solid var(--border); border-radius:7px;
    padding:8px 10px; font-size:11.5px; color:var(--text-secondary);
    cursor:pointer; text-align:left; font-family:'DM Sans',sans-serif;
    transition:all .12s; margin-bottom:5px; line-height:1.35; font-weight:400;
}
.sug-b:last-child { margin-bottom:0; }
.sug-b:hover { border-color:var(--brand); color:var(--brand); background:var(--brand-light); padding-left:14px; }

/* restore link */
.restore-link {
    color: var(--brand); text-decoration: none; font-size: 9.5px;
    display: inline-flex; align-items: center; gap: 2px;
    transition: opacity .15s;
}
.restore-link:hover { opacity: .7; text-decoration: underline; }
.restore-link i { font-size: 10px; }

/* ─── SESSÕES ANTERIORES ────────────────────────────────── */
.sess-empty { font-size:11.5px; color:var(--text-muted); text-align:center; padding:10px 0; }
.sess-item {
    display:flex; align-items:flex-start; gap:8px;
    padding:8px 0; border-bottom:1px solid var(--surface-2);
    cursor:pointer; transition:background .1s; border-radius:5px;
}
.sess-item:last-child { border-bottom:none; }
.sess-item:hover { background:var(--brand-light); margin:0 -4px; padding:8px 4px; }
.sess-item:hover .sess-title { color:var(--brand); }
.sess-dot-wrap { flex-shrink:0; padding-top:2px; }
.sess-dot { width:6px; height:6px; border-radius:50%; background:var(--brand); }
.sess-info { flex:1; min-width:0; }
.sess-title { font-size:12px; font-weight:500; color:var(--text-primary); white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }
.sess-meta  { font-size:10px; color:var(--text-muted); margin-top:1px; }
.sess-del {
    flex-shrink:0; background:none; border:none; cursor:pointer;
    color:var(--text-muted); font-size:11px; padding:2px 4px; border-radius:4px;
    transition:color .1s; line-height:1;
}
.sess-del:hover { color:#ef4444; }
.sess-actions { display:flex; justify-content:flex-end; margin-top:8px; }
.sess-clear-all {
    font-size:10.5px; color:var(--text-muted); background:none; border:none;
    cursor:pointer; font-family:'DM Sans',sans-serif; padding:0;
    transition:color .1s;
}
.sess-clear-all:hover { color:#ef4444; }
</style>
{% endblock %}

{% block body %}
<div class="radar-root">

    {# ── Input ── #}
    <div class="input-strip">
        <div class="input-main">
            <textarea id="qInput" class="radar-textarea" placeholder="Faça uma pergunta estratégica sobre o mercado…" rows="1"></textarea>
            <button id="askBtn" class="btn-fire">
                <i class="bi bi-send"></i> Analisar
            </button>
        </div>
        <div class="examples-row">
            <span class="ex-label">Exemplos</span>
            <button class="ex-chip" onclick="useEx(this)">Estou caro em quais exames?</button>
            <button class="ex-chip" onclick="useEx(this)">Onde posso subir preço sem perder posição?</button>
            <button class="ex-chip" onclick="useEx(this)">Qual exame está em guerra de preço?</button>
            <button class="ex-chip" onclick="useEx(this)">Existe dumping no mercado?</button>
            <button class="ex-chip" onclick="useEx(this)">Quem está dominando Curitiba?</button>
            <button class="ex-chip" onclick="useEx(this)">Meu posicionamento é premium ou irrelevante?</button>
        </div>
    </div>

    {# ── Grid ── #}
    <div class="radar-grid">

        {# Centro #}
        <div class="center-col">

            <div class="status-row">
                <div class="s-dot" id="sDot"></div>
                <span id="sTxt">Pronto para análise</span>
                <span id="sTime" style="margin-left:auto"></span>
            </div>

            <div id="execArea">
                <div class="exec-empty">
                    <div class="empty-pulse-ring">
                        <div class="empty-icon-inner">
                            <i class="bi bi-radar"></i>
                        </div>
                    </div>
                    <div class="empty-title">Radar Estratégico</div>
                    <div class="empty-sub">Faça uma pergunta e a IA consultará o banco de dados em tempo real, retornando uma análise estruturada.</div>
                    <div class="empty-tags">
                        <span class="empty-tag">Diagnóstico</span>
                        <span class="empty-tag">Evidência</span>
                        <span class="empty-tag">Risco</span>
                        <span class="empty-tag">Recomendação</span>
                    </div>
                </div>
            </div>

            <div class="hist-panel" id="histPanel" style="display:none">
                <div class="hist-hd">
                    <i class="bi bi-clock-history" style="color:var(--brand);font-size:12px"></i>
                    <span class="hist-hd-t">Histórico da sessão</span>
                    <span class="hist-badge" id="histBadge">0</span>
                </div>
                <div class="hist-msgs" id="histMsgs"></div>
                <div class="hist-footer">
                    <textarea id="followInput" class="hist-input" placeholder="Continue a análise…" rows="1"></textarea>
                    <button id="sendBtn" class="hist-send"><i class="bi bi-send"></i></button>
                </div>
            </div>

        </div>

        {# Sidebar #}
        <div class="sidebar-col">

            <div class="side-card">
                <div class="side-hd" onclick="toggleS(this)">
                    <span class="side-hd-t"><i class="bi bi-cpu"></i> Base de Cálculo</span>
                    <i class="bi bi-chevron-up side-chev"></i>
                </div>
                <div class="side-body closed" id="calcBody" closed>
                    <div style="font-size:11.5px;color:var(--text-muted);text-align:center;padding:8px 0">Aguardando análise…</div>
                </div>
            </div>

            <div class="side-card">
                <div class="side-hd" onclick="toggleS(this)">
                    <span class="side-hd-t"><i class="bi bi-layers"></i> Fontes de Dados</span>
                    <i class="bi bi-chevron-up side-chev"></i>
                </div>
                <div class="side-body closed" closed>
                    <div class="src-r"><div class="src-dot"></div>market_price_snapshots</div>
                    <div class="src-r"><div class="src-dot"></div>market_procedures</div>
                    <div class="src-r"><div class="src-dot"></div>market_units</div>
                    <div class="src-r"><div class="src-dot" style="background:var(--border-2)"></div>collection_logs</div>
                </div>
            </div>

            <div class="side-card">
                <div class="side-hd" onclick="toggleS(this)">
                    <span class="side-hd-t"><i class="bi bi-terminal"></i> Sugestões de Análise</span>
                    <i class="bi bi-chevron-up side-chev"></i>
                </div>
                <div class="side-body closed" closed>
                    <button class="sug-b" onclick="useSug(this)">Qual exame tem maior dispersão de preço?</button>
                    <button class="sug-b" onclick="useSug(this)">Top 5 exames mais baratos hoje</button>
                    <button class="sug-b" onclick="useSug(this)">Quantas unidades monitoradas esta semana?</button>
                    <button class="sug-b" onclick="useSug(this)">Evolução do hemograma nos últimos 30 dias</button>
                    <button class="sug-b" onclick="useSug(this)">Qual laboratório cobra mais caro no mercado?</button>
                </div>
            </div>


            <div class="side-card" id="sessionsCard">
                <div class="side-hd" onclick="toggleS(this)">
                    <span class="side-hd-t"><i class="bi bi-clock-history"></i> Sessões Anteriores</span>
                    <i class="bi bi-chevron-up side-chev"></i>
                </div>
                <div class="side-body closed" id="sessBody" closed>
                    <div class="sess-empty">Nenhuma sessão salva ainda.</div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}

{% block extra_js %}
<script src="https://cdn.jsdelivr.net/npm/marked@9.1.6/marked.min.js"></script>
<script>
'use strict';
marked.setOptions({ breaks: true, gfm: true });

// ── URLs (Symfony routes) ─────────────────────────────────────────────────────
const URL_CHAT     = '{{ path("ai_assistant_chat") }}';
const URL_SESS_LIST = '{{ path("ai_session_list") }}';
const URL_SESS_SAVE = '{{ path("ai_session_save") }}';
const URL_SESS_LOAD = '/assistente/sessoes/';   // + id
const URL_SESS_DEL  = '/assistente/sessoes/';   // + id  (DELETE)

// ── Helpers ───────────────────────────────────────────────────────────────────
const esc     = s => String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
const escAttr = s => String(s).replace(/"/g,'&quot;');
const fmtTime = () => new Date().toLocaleTimeString('pt-BR',{hour:'2-digit',minute:'2-digit'});
const fmtDate = ts => new Date(ts).toLocaleDateString('pt-BR',{day:'2-digit',month:'short',hour:'2-digit',minute:'2-digit'});
const genId   = () => Date.now().toString(36) + Math.random().toString(36).slice(2,7);

// ── State ─────────────────────────────────────────────────────────────────────
let history             = [];
let msgCount            = 0;
let responseStore       = [];   // [{parsed, clean}]
let currentSessionId    = genId();
let currentSessionTitle = null;

// ── DOM ───────────────────────────────────────────────────────────────────────
const qInput      = document.getElementById('qInput');
const askBtn      = document.getElementById('askBtn');
const execArea    = document.getElementById('execArea');
const histPanel   = document.getElementById('histPanel');
const histMsgs    = document.getElementById('histMsgs');
const histBadge   = document.getElementById('histBadge');
const followInput = document.getElementById('followInput');
const sendBtn     = document.getElementById('sendBtn');
const calcBody    = document.getElementById('calcBody');
const sDot        = document.getElementById('sDot');
const sTxt        = document.getElementById('sTxt');
const sTime       = document.getElementById('sTime');
const sessBody    = document.getElementById('sessBody');

// ── Sidebar toggle ────────────────────────────────────────────────────────────
function toggleS(hd) {
    hd.classList.toggle('open');
    hd.nextElementSibling.classList.toggle('closed');
}

// ── Status bar ────────────────────────────────────────────────────────────────
function setStatus(busy, msg) {
    sDot.className = 's-dot' + (busy ? ' busy' : '');
    sTxt.textContent = msg;
}

// ── Empty state ───────────────────────────────────────────────────────────────
function showEmpty() {
    execArea.innerHTML = `
        <div class="exec-empty">
            <div class="empty-pulse-ring"><div class="empty-icon-inner"><i class="bi bi-radar"></i></div></div>
            <div class="empty-title">Radar Estratégico</div>
            <div class="empty-sub">Faça uma pergunta e a IA consultará o banco de dados em tempo real, retornando uma análise estruturada.</div>
            <div class="empty-tags">
                <span class="empty-tag">Diagnóstico</span>
                <span class="empty-tag">Evidência</span>
                <span class="empty-tag">Risco</span>
                <span class="empty-tag">Recomendação</span>
            </div>
        </div>`;
}

// ── Parse IA JSON ─────────────────────────────────────────────────────────────
function parseAI(text) {
    const m = text.match(/```json\s*([\s\S]*?)```/i)
           || [null, text.match(/(\{[\s\S]*?"diagnostico"[\s\S]*?\})/)?.[1]];
    if (m && m[1]) { try { return JSON.parse(m[1]); } catch(e) {} }
    return { diagnostico: text, evidencia: null, risco: null, recomendacao: null };
}

function cleanText(raw) {
    return raw.replace(/```json[\s\S]*?```/gi, '').trim()
           || 'Análise concluída — veja os cards acima.';
}

// ── Render cards 2×2 ──────────────────────────────────────────────────────────
function renderCards(p) {
    let evidHtml = '<span style="color:var(--text-muted);font-size:12px">Sem dados quantitativos.</span>';
    if (p.evidencia && typeof p.evidencia === 'object' && !Array.isArray(p.evidencia)) {
        evidHtml = '<table class="kv">' +
            Object.entries(p.evidencia).map(([k,v]) =>
                `<tr><td>${esc(k)}</td><td>${esc(String(v))}</td></tr>`
            ).join('') + '</table>';
    } else if (p.evidencia) {
        evidHtml = marked.parse(String(p.evidencia));
    }
    execArea.innerHTML = `
        <div class="exec-cards">
            <div class="ec ec-diag">
                <div class="ec-head"><div class="ec-ico"><i class="bi bi-search"></i></div><span class="ec-lbl">Diagnóstico</span></div>
                <div class="ec-body">${marked.parse(p.diagnostico || '—')}</div>
            </div>
            <div class="ec ec-evid">
                <div class="ec-head"><div class="ec-ico"><i class="bi bi-bar-chart-line"></i></div><span class="ec-lbl">Evidência</span></div>
                <div class="ec-body">${evidHtml}</div>
            </div>
            <div class="ec ec-risk">
                <div class="ec-head"><div class="ec-ico"><i class="bi bi-shield-exclamation"></i></div><span class="ec-lbl">Risco</span></div>
                <div class="ec-body">${p.risco ? marked.parse(p.risco) : '<span style="color:var(--text-muted);font-size:12px">Nenhum risco crítico identificado.</span>'}</div>
            </div>
            <div class="ec ec-recom">
                <div class="ec-head"><div class="ec-ico"><i class="bi bi-arrow-right-circle"></i></div><span class="ec-lbl">Recomendação</span></div>
                <div class="ec-body">${p.recomendacao ? marked.parse(p.recomendacao) : '<span style="color:var(--text-muted);font-size:12px">Aguardando análise completa.</span>'}</div>
            </div>
        </div>`;
}

function renderCalc(p) {
    calcBody.innerHTML = `
        <div class="calc-r"><span class="calc-lbl">Período</span><span class="calc-val">${esc(p.periodo || new Date().toLocaleDateString('pt-BR'))}</span></div>
        <div class="calc-r"><span class="calc-lbl">Unidades analisadas</span><span class="calc-val">${esc(String(p.n_unidades||'—'))}</span></div>
        <div class="calc-r"><span class="calc-lbl">Exames analisados</span><span class="calc-val">${esc(String(p.n_exames||'—'))}</span></div>
        ${p.query ? `<div class="qpre">${esc(p.query)}</div>` : ''}`;
}

function restoreCards(idx) {
    const r = responseStore[idx];
    if (!r) return;
    renderCards(r.parsed);
    renderCalc(r.parsed);
    execArea.style.outline = '2px solid var(--brand)';
    setTimeout(() => { execArea.style.outline = ''; }, 800);
    execArea.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
}

// ── Chat messages ─────────────────────────────────────────────────────────────
function addMsg(role, text, tools = [], storeIdx = null) {
    histPanel.style.display = 'flex';
    const badges = tools.map(t => `<span class="tool-t"><i class="bi bi-database"></i> ${t}</span>`).join('');
    const link   = storeIdx !== null
        ? ` · <a href="#" class="restore-link" onclick="restoreCards(${storeIdx});return false"><i class="bi bi-arrow-up-left-square"></i> ver nos cards</a>`
        : '';
    const row = document.createElement('div');
    row.className = 'msg-r' + (role === 'user' ? ' user' : '');
    row.innerHTML = role === 'user'
        ? `<div><div class="msg-b user">${esc(text)}</div><div class="msg-meta" style="text-align:right">${fmtTime()}</div></div><div class="msg-av user"><i class="bi bi-person"></i></div>`
        : `<div class="msg-av ai"><i class="bi bi-cpu"></i></div><div><div class="msg-b ai">${marked.parse(text)}</div><div class="msg-meta">${fmtTime()}${badges ? ' · ' + badges : ''}${link}</div></div>`;
    histMsgs.appendChild(row);
    histMsgs.scrollTop = histMsgs.scrollHeight;
}

function showTyping() {
    const el = document.createElement('div');
    el.id = 'typin'; el.className = 'msg-r';
    el.innerHTML = `<div class="msg-av ai"><i class="bi bi-cpu"></i></div><div class="msg-b ai"><div class="typing"><div class="td"></div><div class="td"></div><div class="td"></div></div></div>`;
    histMsgs.appendChild(el);
    histMsgs.scrollTop = histMsgs.scrollHeight;
}
function removeTyping() { document.getElementById('typin')?.remove(); }

function showLoadingCards() {
    execArea.innerHTML = `<div class="exec-loading"><div class="load-bar"></div><div class="load-lbl">Consultando banco de dados…</div></div>`;
}

// ── Main chat logic ───────────────────────────────────────────────────────────
async function doChat(text) {
    if (!currentSessionTitle) {
        currentSessionTitle = text.trim().replace(/[?!.,;]+$/, '').slice(0, 80);
    }
    addMsg('user', text);
    showTyping();
    showLoadingCards();
    setStatus(true, 'Analisando…');
    history.push({ role: 'user', content: text });

    try {
        const res  = await fetch(URL_CHAT, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ message: text, history: history.slice(0, -1) }),
        });
        const data = await res.json();
        removeTyping();

        if (data.success) {
            const parsed   = parseAI(data.message);
            const clean    = cleanText(data.message);
            const storeIdx = responseStore.length;
            responseStore.push({ parsed, clean });

            renderCards(parsed);
            renderCalc(parsed);
            addMsg('assistant', clean, data.tools_used || [], storeIdx);

            msgCount++;
            histBadge.textContent = msgCount;
            history.push({ role: 'assistant', content: data.message });
            if (history.length > 40) history = history.slice(-40);

            setStatus(false, 'Análise concluída');
            sTime.textContent = fmtTime();
            saveSession();  // fire and forget
        } else {
            showError(data.error || 'Falha desconhecida.');
        }
    } catch (err) {
        removeTyping();
        showError('Erro de conexão. Verifique a rede.', true);
        console.error(err);
    }
}

function showError(msg, network = false) {
    const icon = network ? 'bi-wifi-off' : 'bi-exclamation-triangle';
    execArea.innerHTML = `<div class="exec-empty"><div class="empty-pulse-ring"><div class="empty-icon-inner" style="background:#fee2e2;color:#dc2626"><i class="bi ${icon}"></i></div></div><div class="empty-title" style="color:#dc2626;font-size:16px">Erro</div><div class="empty-sub">${esc(msg)}</div></div>`;
    addMsg('assistant', 'Erro: ' + msg);
    setStatus(false, 'Erro');
}

async function sendQuestion() {
    const text = qInput.value.trim();
    if (!text) return;
    qInput.value = ''; qInput.style.height = 'auto';
    askBtn.disabled = true;
    await doChat(text);
    askBtn.disabled = false;
    qInput.focus();
}

async function sendFollowUp() {
    const text = followInput.value.trim();
    if (!text) return;
    followInput.value = ''; followInput.style.height = 'auto';
    sendBtn.disabled = true;
    await doChat(text);
    sendBtn.disabled = false;
    followInput.focus();
}

function clearChat() {
    history = []; msgCount = 0; responseStore = [];
    currentSessionId    = genId();
    currentSessionTitle = null;
    showEmpty();
    histMsgs.innerHTML = '';
    histPanel.style.display = 'none';
    histBadge.textContent = '0';
    calcBody.innerHTML = '<div style="font-size:11.5px;color:var(--text-muted);text-align:center;padding:8px 0">Aguardando análise…</div>';
    setStatus(false, 'Pronto para análise');
    sTime.textContent = '';
    qInput.focus();
}

// ── Session persistence (banco via Symfony) ───────────────────────────────────
function serializeMsgs() {
    const msgs = [];
    histMsgs.querySelectorAll('.msg-r').forEach(row => {
        const bub = row.querySelector('.msg-b');
        if (bub) msgs.push({
            role: row.classList.contains('user') ? 'user' : 'assistant',
            html: bub.innerHTML,
        });
    });
    return msgs;
}

async function saveSession() {
    if (msgCount === 0) return;
    try {
        await fetch(URL_SESS_SAVE, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
                id:        currentSessionId,
                title:     currentSessionTitle || 'Sessão sem título',
                history,
                responses: responseStore,
                msgs:      serializeMsgs(),
                msgCount,
            }),
        });
        loadSessionList();
    } catch(e) { console.error('saveSession:', e); }
}

async function loadSessionList() {
    try {
        const res  = await fetch(URL_SESS_LIST);
        const data = await res.json();
        if (!data.success || data.sessions.length === 0) {
            sessBody.innerHTML = '<div class="sess-empty">Nenhuma sessão salva ainda.</div>';
            return;
        }
        const items = data.sessions.map(s => `
            <div class="sess-item" onclick="openSession('${escAttr(s.id)}')">
                <div class="sess-dot-wrap"><div class="sess-dot" style="${s.id === currentSessionId ? 'background:#22c55e' : ''}"></div></div>
                <div class="sess-info">
                    <div class="sess-title" title="${escAttr(s.title)}">${esc(s.title)}</div>
                    <div class="sess-meta">${s.msgCount} pergunta${s.msgCount !== 1 ? 's' : ''} · ${fmtDate(s.updatedAt)}</div>
                </div>
                <button class="sess-del" onclick="deleteSession(event,'${escAttr(s.id)}')" title="Apagar"><i class="bi bi-trash"></i></button>
            </div>`).join('');

        const clearAll = data.sessions.length > 1
            ? `<div class="sess-actions"><button class="sess-clear-all" onclick="clearAllSessions()">Apagar todas</button></div>` : '';

        sessBody.innerHTML = items + clearAll;
    } catch(e) {
        sessBody.innerHTML = '<div class="sess-empty">Erro ao carregar sessões.</div>';
        console.error('loadSessionList:', e);
    }
}

async function openSession(id) {
    try {
        const res  = await fetch(URL_SESS_LOAD + encodeURIComponent(id));
        const data = await res.json();
        if (!data.success) return;

        const s = data.session;
        history             = s.history   || [];
        responseStore       = s.responses || [];
        msgCount            = s.msgCount  || 0;
        currentSessionId    = s.id;
        currentSessionTitle = s.title;

        // Restore last cards
        if (responseStore.length > 0) {
            renderCards(responseStore[responseStore.length - 1].parsed);
            renderCalc(responseStore[responseStore.length - 1].parsed);
        } else { showEmpty(); }

        // Restore messages
        histMsgs.innerHTML = '';
        let aiIdx = 0;
        (s.msgs || []).forEach(m => {
            const row = document.createElement('div');
            row.className = 'msg-r' + (m.role === 'user' ? ' user' : '');
            if (m.role === 'user') {
                row.innerHTML = `<div><div class="msg-b user">${m.html}</div><div class="msg-meta" style="text-align:right"></div></div><div class="msg-av user"><i class="bi bi-person"></i></div>`;
            } else {
                const si  = aiIdx < responseStore.length ? aiIdx : null;
                const lnk = si !== null
                    ? ` · <a href="#" class="restore-link" onclick="restoreCards(${si});return false"><i class="bi bi-arrow-up-left-square"></i> ver nos cards</a>` : '';
                row.innerHTML = `<div class="msg-av ai"><i class="bi bi-cpu"></i></div><div><div class="msg-b ai">${m.html}</div><div class="msg-meta">${lnk}</div></div>`;
                aiIdx++;
            }
            histMsgs.appendChild(row);
        });

        histPanel.style.display = 'flex';
        histBadge.textContent   = msgCount;
        histMsgs.scrollTop      = histMsgs.scrollHeight;
        setStatus(false, 'Sessão restaurada: ' + s.title);
        sTime.textContent = fmtDate(s.updatedAt);
        await loadSessionList();
    } catch(e) { console.error('openSession:', e); }
}

async function deleteSession(e, id) {
    e.stopPropagation();
    try {
        await fetch(URL_SESS_DEL + encodeURIComponent(id), { method: 'DELETE' });
        if (id === currentSessionId) clearChat();
        else loadSessionList();
    } catch(e2) { console.error(e2); }
}

async function clearAllSessions() {
    try {
        const res  = await fetch(URL_SESS_LIST);
        const data = await res.json();
        await Promise.all((data.sessions || []).map(s =>
            fetch(URL_SESS_DEL + encodeURIComponent(s.id), { method: 'DELETE' })
        ));
        clearChat();
        await loadSessionList();
    } catch(e) { console.error(e); }
}

// ── Events ────────────────────────────────────────────────────────────────────
askBtn.addEventListener('click', sendQuestion);
qInput.addEventListener('keydown', e => { if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); sendQuestion(); } });
qInput.addEventListener('input', () => { qInput.style.height = 'auto'; qInput.style.height = Math.min(qInput.scrollHeight, 100) + 'px'; });
sendBtn.addEventListener('click', sendFollowUp);
followInput.addEventListener('keydown', e => { if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); sendFollowUp(); } });
followInput.addEventListener('input', () => { followInput.style.height = 'auto'; followInput.style.height = Math.min(followInput.scrollHeight, 70) + 'px'; });

function useEx(btn) { qInput.value = btn.textContent.trim(); qInput.focus(); }
function useSug(btn) { qInput.value = btn.textContent.trim(); qInput.focus(); }

// ── Init ──────────────────────────────────────────────────────────────────────
loadSessionList();
</script>
{% endblock %}
