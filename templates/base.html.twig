<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}Market Intelligence{% endblock %} · LANAC</title>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600;700&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css">

    <style>
        /* ══════════════════════════════════════════════════════
           DESIGN TOKENS
        ══════════════════════════════════════════════════════ */
        :root {
            --sidebar-w: 240px;

            --bg:          #f5f6fa;
            --surface:     #ffffff;
            --surface-2:   #f0f2f8;
            --border:      #e4e7f0;
            --border-2:    #d1d8e8;

            --text-primary:   #1a1d2e;
            --text-secondary: #5a6072;
            --text-muted:     #9399ad;

            --brand:        #2563eb;
            --brand-light:  #dbeafe;
            --brand-dark:   #1d4ed8;

            --green:  #059669;
            --green-bg: #d1fae5;
            --red:    #dc2626;
            --red-bg: #fee2e2;
            --amber:  #d97706;
            --amber-bg: #fef3c7;

            --radius:    10px;
            --radius-lg: 14px;
            --shadow:    0 1px 4px rgba(0,0,0,.06), 0 4px 16px rgba(0,0,0,.04);
            --shadow-md: 0 2px 8px rgba(0,0,0,.08), 0 8px 24px rgba(0,0,0,.06);
        }

        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
        html { font-size: 14px; -webkit-font-smoothing: antialiased; }
        body {
            font-family: 'DM Sans', sans-serif;
            background: var(--bg);
            color: var(--text-primary);
            display: flex;
            min-height: 100vh;
        }

        /* ══════════════════════════════════════════════════════
           SIDEBAR
        ══════════════════════════════════════════════════════ */
        #sidebar {
            width: var(--sidebar-w);
            background: var(--surface);
            border-right: 1px solid var(--border);
            display: flex;
            flex-direction: column;
            position: fixed;
            top: 0; left: 0;
            height: 100vh;
            z-index: 50;
            transition: transform .25s ease;
        }

        .sidebar-logo {
            padding: 20px 20px 16px;
            border-bottom: 1px solid var(--border);
            display: flex;
            align-items: center;
            gap: 10px;
        }
        .sidebar-logo-icon {
            width: 34px; height: 34px;
            background: var(--brand);
            border-radius: 9px;
            display: flex; align-items: center; justify-content: center;
            color: white; font-size: 16px; flex-shrink: 0;
        }
        .sidebar-logo-text { font-size: 15px; font-weight: 700; color: var(--text-primary); line-height: 1.2; }
        .sidebar-logo-text span { display: block; font-size: 11px; font-weight: 400; color: var(--text-muted); }

        .sidebar-nav { flex: 1; padding: 12px 10px; overflow-y: auto; }
        .nav-section-label {
            font-size: 10px; font-weight: 600; letter-spacing: .08em;
            text-transform: uppercase; color: var(--text-muted);
            padding: 8px 10px 4px; margin-top: 4px;
        }
        .nav-item {
            display: flex; align-items: center; gap: 9px;
            padding: 8px 10px; border-radius: var(--radius);
            color: var(--text-secondary); font-size: 13.5px; font-weight: 500;
            text-decoration: none; transition: all .15s ease; margin-bottom: 1px;
        }
        .nav-item i { font-size: 15px; width: 18px; text-align: center; }
        .nav-item:hover  { background: var(--surface-2); color: var(--text-primary); }
        .nav-item.active { background: var(--brand-light); color: var(--brand); }
        .nav-item.active i { color: var(--brand); }

        .sidebar-footer { padding: 14px 16px; border-top: 1px solid var(--border); }
        .sidebar-footer-text { font-size: 11px; color: var(--text-muted); display: flex; align-items: center; gap: 6px; }

        /* ══════════════════════════════════════════════════════
           MAIN
        ══════════════════════════════════════════════════════ */
        #main { margin-left: var(--sidebar-w); flex: 1; display: flex; flex-direction: column; min-height: 100vh; }

        /* ── TOPBAR ─────────────────────────────────────────
           Estrutura: [título fixo] | [filtros flex:1] | [ações auto]
           Tudo em uma única linha — sem wrap
        ─────────────────────────────────────────────────── */
        .topbar {
            background: var(--surface);
            border-bottom: 1px solid var(--border);
            padding: 0 28px;
            height: 58px;
            display: flex;
            align-items: center;
            gap: 20px;
            flex-wrap: nowrap;
            position: sticky;
            top: 0;
            z-index: 40;
        }

        /* título — nunca encolhe */
        .topbar-left { flex-shrink: 0; padding: 8px 0; }
        .topbar-title    { font-size: 17px; font-weight: 700; color: var(--text-primary); }
        .topbar-subtitle { font-size: 12px; color: var(--text-muted); margin-top: 1px; }

        /* filtros contextuais — ocupa o espaço central disponível
           Quando vazio (páginas sem filtros), colapsa para zero */
        .topbar-filters {
            flex: 1;
            display: flex;
            align-items: center;
            padding: 0;
            min-width: 0;
            overflow: hidden;
        }
        .topbar-filters:empty { flex: 0; }

        /* ações — sempre à direita, nunca encolhem */
        .topbar-actions {
            flex-shrink: 0;
            margin-left: auto;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .topbar-date {
            font-size: 12px; color: var(--text-muted);
            background: var(--surface-2); padding: 5px 11px;
            border-radius: 20px; border: 1px solid var(--border);
        }

        /* ── Classes das páginas que usam topbar_filters ── */
        .topbar-filter-form {
            display: flex;
            align-items: center;   /* alinha verticalmente no centro da topbar */
            gap: 10px;
            flex-wrap: nowrap;
            height: 100%;
        }
        .topbar-filter-group { display: flex; flex-direction: column; gap: 3px; }
        .topbar-filter-label {
            font-size: 10px; font-weight: 700; text-transform: uppercase;
            letter-spacing: .05em; color: var(--text-muted);
        }
        .topbar-filter-input,
        .topbar-filter-select {
            height: 32px; border: 1px solid var(--border-2); border-radius: 7px;
            padding: 0 10px; font-family: 'DM Sans', sans-serif; font-size: 12.5px;
            color: var(--text-primary); background: var(--bg);
            outline: none; transition: border-color .15s;
        }
        .topbar-filter-input:focus,
        .topbar-filter-select:focus { border-color: var(--brand); }
        .topbar-filter-btn {
            height: 32px; display: flex; align-items: center; gap: 5px;
            background: var(--brand); color: #fff; border: none; border-radius: 7px;
            padding: 0 14px; font-size: 12.5px; font-weight: 600; cursor: pointer;
            transition: background .12s; font-family: 'DM Sans', sans-serif; white-space: nowrap;
        }
        .topbar-filter-btn:hover { background: var(--brand-dark); }
        .topbar-filter-reset {
            height: 32px; width: 32px; display: flex; align-items: center; justify-content: center;
            border: 1px solid var(--border); border-radius: 7px; color: var(--text-muted);
            text-decoration: none; transition: background .12s, color .12s; margin-left: 2px;
        }
        .topbar-filter-reset:hover { background: var(--red-bg); color: var(--red); border-color: var(--red); }

        /* Select2 dentro da topbar — altura 32px em vez de 36px */
        .topbar-filters .select2-container--default .select2-selection--single { height: 32px; min-height: 32px; }
        .topbar-filters .select2-container--default .select2-selection--single .select2-selection__rendered { line-height: 30px; }
        .topbar-filters .select2-container--default .select2-selection--single .select2-selection__arrow { height: 30px; }

        /* ── Page body ── */
        .page-body { padding: 24px 28px; flex: 1; }

        /* ══════════════════════════════════════════════════════
           FILTER BAR (card dentro da página)
        ══════════════════════════════════════════════════════ */
        .filter-bar {
            background: var(--surface); border: 1px solid var(--border);
            border-radius: var(--radius-lg); padding: 16px 20px;
            display: flex; align-items: flex-end; gap: 14px; flex-wrap: wrap;
            margin-bottom: 22px; box-shadow: var(--shadow);
        }
        .filter-group { display: flex; flex-direction: column; gap: 5px; min-width: 140px; }
        .filter-group.wide { min-width: 200px; }
        .filter-label { font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: .05em; color: var(--text-muted); }
        .filter-input,
        .filter-select {
            height: 36px; padding: 0 10px; border: 1px solid var(--border-2);
            border-radius: 8px; background: var(--bg); color: var(--text-primary);
            font-family: 'DM Sans', sans-serif; font-size: 13px;
            outline: none; transition: border-color .15s, box-shadow .15s;
        }
        .filter-input:focus,
        .filter-select:focus { border-color: var(--brand); box-shadow: 0 0 0 3px rgba(37,99,235,.12); }
        .filter-select[multiple] { height: auto; min-height: 36px; max-height: 90px; padding: 4px 8px; }
        .btn-filter { height: 36px; padding: 0 18px; border-radius: 8px; border: none; cursor: pointer; font-family: 'DM Sans', sans-serif; font-size: 13px; font-weight: 600; transition: all .15s; }
        .btn-primary-filter { background: var(--brand); color: white; }
        .btn-primary-filter:hover { background: var(--brand-dark); transform: translateY(-1px); }
        .btn-reset-filter { background: var(--surface-2); color: var(--text-secondary); border: 1px solid var(--border); }
        .btn-reset-filter:hover { background: var(--border); }

        /* ══════════════════════════════════════════════════════
           KPI CARDS
        ══════════════════════════════════════════════════════ */
        .kpi-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: 14px; margin-bottom: 22px; }
        .kpi-card { background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius-lg); padding: 18px 20px; box-shadow: var(--shadow); transition: box-shadow .2s, transform .2s; position: relative; overflow: hidden; }
        .kpi-card:hover { box-shadow: var(--shadow-md); transform: translateY(-2px); }
        .kpi-card::before { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 3px; background: var(--brand); border-radius: var(--radius-lg) var(--radius-lg) 0 0; }
        .kpi-card.green::before { background: var(--green); }
        .kpi-card.red::before   { background: var(--red); }
        .kpi-card.amber::before { background: var(--amber); }
        .kpi-header { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 12px; }
        .kpi-icon { width: 36px; height: 36px; border-radius: 9px; display: flex; align-items: center; justify-content: center; font-size: 16px; }
        .kpi-icon.blue  { background: var(--brand-light); color: var(--brand); }
        .kpi-icon.green { background: var(--green-bg);   color: var(--green); }
        .kpi-icon.red   { background: var(--red-bg);     color: var(--red); }
        .kpi-icon.amber { background: var(--amber-bg);   color: var(--amber); }
        .kpi-badge { display: inline-flex; align-items: center; gap: 3px; font-size: 11px; font-weight: 600; padding: 2px 7px; border-radius: 12px; }
        .kpi-badge.up   { background: var(--green-bg); color: var(--green); }
        .kpi-badge.down { background: var(--red-bg);   color: var(--red); }
        .kpi-badge.flat { background: var(--surface-2); color: var(--text-muted); }
        .kpi-value { font-size: 26px; font-weight: 700; color: var(--text-primary); line-height: 1.1; font-variant-numeric: tabular-nums; letter-spacing: -.5px; }
        .kpi-label { font-size: 12px; color: var(--text-muted); margin-top: 4px; font-weight: 400; }

        /* ══════════════════════════════════════════════════════
           CHART CARDS
        ══════════════════════════════════════════════════════ */
        .chart-row { display: grid; gap: 14px; margin-bottom: 22px; }
        .chart-row-3 { grid-template-columns: 2fr 1fr; }
        .chart-row-2 { grid-template-columns: 1fr; }
        .card { background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius-lg); box-shadow: var(--shadow); overflow: hidden; }
        .card-header { padding: 16px 20px 0; display: flex; align-items: center; justify-content: space-between; }
        .card-title   { font-size: 14px; font-weight: 700; color: var(--text-primary); }
        .card-subtitle{ font-size: 11px; color: var(--text-muted); margin-top: 2px; }
        .card-body    { padding: 16px 20px 20px; }
        .chart-wrap    { position: relative; height: 260px; }
        .chart-wrap-sm { position: relative; height: 220px; }

        /* ══════════════════════════════════════════════════════
           TABLE
        ══════════════════════════════════════════════════════ */
        .data-table { width: 100%; border-collapse: collapse; font-size: 13px; }
        .data-table thead th { font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: .05em; color: var(--text-muted); padding: 10px 14px; border-bottom: 1px solid var(--border); text-align: left; background: var(--surface-2); }
        .data-table tbody tr { border-bottom: 1px solid var(--border); transition: background .12s; }
        .data-table tbody tr:last-child { border-bottom: none; }
        .data-table tbody tr:hover { background: var(--surface-2); }
        .data-table td { padding: 11px 14px; color: var(--text-primary); }
        .data-table td.muted { color: var(--text-muted); }
        .data-table td.mono  { font-family: 'DM Mono', monospace; font-size: 12px; }
        .badge { display: inline-flex; align-items: center; padding: 2px 8px; border-radius: 10px; font-size: 11px; font-weight: 600; }
        .badge-blue  { background: var(--brand-light); color: var(--brand); }
        .badge-green { background: var(--green-bg);    color: var(--green); }
        .badge-amber { background: var(--amber-bg);    color: var(--amber); }
        .badge-red   { background: var(--red-bg);      color: var(--red); }
        .badge-gray  { background: var(--surface-2);   color: var(--text-muted); }

        /* ══════════════════════════════════════════════════════
           UTILITIES
        ══════════════════════════════════════════════════════ */
        .empty-state { text-align: center; padding: 40px 20px; color: var(--text-muted); }
        .empty-state i { font-size: 32px; margin-bottom: 10px; display: block; }
        .empty-state p { font-size: 13px; }
        ::-webkit-scrollbar { width: 5px; height: 5px; }
        ::-webkit-scrollbar-track { background: transparent; }
        ::-webkit-scrollbar-thumb { background: var(--border-2); border-radius: 3px; }

        /* ══════════════════════════════════════════════════════
           SELECT2
        ══════════════════════════════════════════════════════ */
        .select2-container--default .select2-selection--multiple,
        .select2-container--default .select2-selection--single { background: var(--bg); border: 1px solid var(--border-2); border-radius: 8px; min-height: 36px; font-family: 'DM Sans', sans-serif; font-size: 13px; }
        .select2-container--default .select2-selection--single { height: 36px; display: flex; align-items: center; }
        .select2-container--default .select2-selection--single .select2-selection__rendered { color: var(--text-primary); line-height: 36px; padding-left: 10px; }
        .select2-container--default .select2-selection--single .select2-selection__arrow { height: 34px; }
        .select2-container--default .select2-selection--multiple .select2-selection__rendered { padding: 2px 6px; }
        .select2-container--default .select2-selection--multiple .select2-selection__choice { background: var(--brand-light); border: 1px solid #bfdbfe; color: var(--brand); border-radius: 6px; font-size: 11px; font-weight: 600; padding: 1px 6px; }
        .select2-container--default .select2-selection--multiple .select2-selection__choice__remove { color: var(--brand); margin-right: 4px; }
        .select2-dropdown { border: 1px solid var(--border-2); border-radius: 10px; box-shadow: var(--shadow-md); font-family: 'DM Sans', sans-serif; font-size: 13px; overflow: hidden; }
        .select2-container--default .select2-results__option--highlighted[aria-selected] { background: var(--brand); }
        .select2-container--default .select2-results__option[aria-selected=true] { background: var(--brand-light); color: var(--brand); }
        .select2-search--dropdown .select2-search__field { border: 1px solid var(--border-2); border-radius: 6px; font-family: 'DM Sans', sans-serif; font-size: 12px; padding: 5px 8px; outline: none; }
        .select2-container--default.select2-container--focus .select2-selection--multiple { border-color: var(--brand); box-shadow: 0 0 0 3px rgba(37,99,235,.12); }

        /* ══════════════════════════════════════════════════════
           AUTO-REFRESH
        ══════════════════════════════════════════════════════ */
        .refresh-bar { display: flex; align-items: center; gap: 8px; font-size: 11px; color: var(--text-muted); }
        .refresh-dot { width: 7px; height: 7px; border-radius: 50%; background: var(--green); animation: none; }
        .refresh-dot.spinning { animation: pulse-green 1s ease infinite; }
        @keyframes pulse-green { 0%, 100% { opacity: 1; transform: scale(1); } 50% { opacity: .4; transform: scale(.7); } }
        .refresh-countdown { font-variant-numeric: tabular-nums; font-family: 'DM Mono', monospace; font-size: 10px; }
        .btn-refresh { background: transparent; border: 1px solid var(--border); border-radius: 7px; padding: 3px 9px; font-family: 'DM Sans', sans-serif; font-size: 11px; font-weight: 600; color: var(--text-secondary); cursor: pointer; transition: all .15s; display: flex; align-items: center; gap: 4px; }
        .btn-refresh:hover { background: var(--surface-2); border-color: var(--brand); color: var(--brand); }
        .btn-refresh.refreshing i { animation: spin .6s linear infinite; }
        @keyframes spin { to { transform: rotate(360deg); } }
        .btn-csv { display: inline-flex; align-items: center; gap: 5px; padding: 5px 12px; border-radius: 8px; border: 1px solid var(--border); background: var(--surface-2); color: var(--text-secondary); font-family: 'DM Sans', sans-serif; font-size: 12px; font-weight: 600; cursor: pointer; text-decoration: none; transition: all .15s; }
        .btn-csv:hover { background: var(--green-bg); border-color: var(--green); color: var(--green); }
    </style>

    {# extra_css FORA do <style> do base — cada página injeta sua própria tag <style> #}
    {% block extra_css %}{% endblock %}
</head>
<body>

{# ════════════════════════════
   SIDEBAR
════════════════════════════ #}
<aside id="sidebar">
    <div class="sidebar-logo">
        <div class="sidebar-logo-icon"><i class="bi bi-activity"></i></div>
        <div class="sidebar-logo-text">
            LANAC
            <span>Market Intelligence</span>
        </div>
    </div>

    <nav class="sidebar-nav">
        <div class="nav-section-label">Painéis</div>
        <a href="{{ path('dashboard_index') }}"
           class="nav-item {{ app.request.attributes.get('_route') == 'dashboard_index' ? 'active' }}">
            <i class="bi bi-grid-1x2-fill"></i> Visão Geral
        </a>
        <a href="{{ path('procedure_analysis_index') }}"
           class="nav-item {{ app.request.attributes.get('_route') starts with 'procedure_analysis' ? 'active' }}">
            <i class="bi bi-bar-chart-line-fill"></i> Análise por Exame
        </a>
        <a href="{{ path('unit_comparison_index') }}"
           class="nav-item {{ app.request.attributes.get('_route') starts with 'unit_comparison' ? 'active' }}">
            <i class="bi bi-building"></i> Comparativo Unidades
        </a>
        <a href="{{ path('price_simulation_index') }}"
           class="nav-item {{ app.request.attributes.get('_route') starts with 'price_simulation' ? 'active' }}">
            <i class="bi bi-sliders"></i> Simulação de Preços
        </a>
        <a href="{{ path('data_quality_index') }}"
           class="nav-item {{ app.request.attributes.get('_route') starts with 'data_quality' ? 'active' }}">
            <i class="bi bi-shield-check"></i> Qualidade & Logs
        </a>
        <div class="nav-section-label" style="margin-top:8px">Inteligência</div>
        <a href="{{ path('ai_assistant_index') }}"
           class="nav-item {{ app.request.attributes.get('_route') starts with 'ai_assistant' ? 'active' }}">
            <i class="bi bi-robot"></i> Assistente IA
        </a>
    </nav>

    <div class="sidebar-footer">
        <div class="sidebar-footer-text">
            <i class="bi bi-circle-fill" style="color:var(--green);font-size:7px"></i>
            Sistema operacional
        </div>
    </div>
</aside>

{# ════════════════════════════
   MAIN
════════════════════════════ #}
<div id="main">

    {# ── TOPBAR ──────────────────────────────────────────────────────────────
       Estrutura: [título] | [filtros contextuais?] | [ações + data]

       Páginas que precisam de filtros declaram {% block topbar_filters %}.
       Páginas sem filtros (Visão Geral, Assistente IA) não declaram o bloco
       e a topbar permanece com altura 58px, idêntica ao original.
    ─────────────────────────────────────────────────────────────────────── #}
    <header class="topbar">

        {# Título + subtítulo — flex-shrink:0, nunca comprime #}
        <div class="topbar-left">
            <div class="topbar-title">{% block page_title %}Dashboard{% endblock %}</div>
            <div class="topbar-subtitle">{% block page_subtitle %}Inteligência de Mercado Laboratorial{% endblock %}</div>
        </div>

        {# Filtros contextuais — cada página define via {% block topbar_filters %}
           A div usa :empty no CSS para colapsar quando não há conteúdo. #}
        <div class="topbar-filters">
            {% block topbar_filters %}{% endblock %}
        </div>

        {# Ações — sempre à direita, flex-shrink:0 #}
        <div class="topbar-actions">
            {% block topbar_actions %}{% endblock %}
            <div class="refresh-bar" id="globalRefreshBar" style="display:none">
                <span class="refresh-dot" id="refreshDot"></span>
                <span>Próximo refresh em <span class="refresh-countdown" id="refreshCountdown">--</span>s</span>
                <button class="btn-refresh" id="refreshNowBtn" title="Atualizar agora">
                    <i class="bi bi-arrow-clockwise"></i> Atualizar
                </button>
            </div>
            <span class="topbar-date">
                <i class="bi bi-calendar3"></i>
                {{ "now"|date("d/m/Y") }}
            </span>
        </div>

    </header>

    <main class="page-body">
        {% block body %}{% endblock %}
    </main>
</div>

{% block extra_js %}{% endblock %}

<script src="https://cdn.jsdelivr.net/npm/jquery@3.7.1/dist/jquery.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>
<script>
// ══════════════════════════════════════════════════════
// GLOBAL: Select2
// ══════════════════════════════════════════════════════
$(document).ready(function () {
    $('.select2-multi').select2({
        placeholder: 'Todos',
        allowClear: true,
        width: '100%',
        language: { noResults: () => 'Nenhum resultado', searching: () => 'Buscando...' },
    });

    $('.select2-single').each(function () {
        const url     = $(this).data('search-url');
        const preId   = $(this).data('selected-id')   || '';
        const preText = $(this).data('selected-text')  || '';

        const cfg = {
            allowClear: true,
            width: '100%',
            minimumInputLength: 0,
            language: {
                noResults:     () => 'Nenhum resultado',
                searching:     () => 'Buscando...',
                inputTooShort: () => 'Digite para buscar...',
            },
        };

        if (url) {
            cfg.ajax = {
                url: url,
                dataType: 'json',
                delay: 250,
                data: params => ({ q: params.term || '' }),
                processResults: data => ({ results: data.results }),
                cache: true,
            };
        }

        $(this).select2(cfg);

        if (preId && preText) {
            const opt = new Option(preText, preId, true, true);
            $(this).append(opt).trigger('change');
        }
    });
});

// ══════════════════════════════════════════════════════
// GLOBAL: Auto-refresh engine
// ══════════════════════════════════════════════════════
window.AutoRefresh = (function () {
    let _seconds   = 60;
    let _remaining = 60;
    let _ticker    = null;
    let _callback  = null;

    const bar       = document.getElementById('globalRefreshBar');
    const dot       = document.getElementById('refreshDot');
    const countdown = document.getElementById('refreshCountdown');
    const nowBtn    = document.getElementById('refreshNowBtn');

    function tick() {
        _remaining--;
        if (countdown) countdown.textContent = _remaining;
        if (_remaining <= 0) triggerRefresh();
    }

    function triggerRefresh() {
        _remaining = _seconds;
        if (dot)    dot.classList.add('spinning');
        if (nowBtn) nowBtn.classList.add('refreshing');
        setTimeout(() => {
            if (dot)    dot.classList.remove('spinning');
            if (nowBtn) nowBtn.classList.remove('refreshing');
        }, 800);
        if (_callback) _callback();
    }

    if (nowBtn) nowBtn.addEventListener('click', () => { _remaining = _seconds; triggerRefresh(); });

    return {
        start(seconds, callback) {
            _seconds = seconds; _remaining = seconds; _callback = callback;
            if (bar)       bar.style.display = 'flex';
            if (countdown) countdown.textContent = _remaining;
            if (_ticker)   clearInterval(_ticker);
            _ticker = setInterval(tick, 1000);
        },
        stop() {
            if (_ticker) clearInterval(_ticker);
            if (bar) bar.style.display = 'none';
        },
    };
})();

// ══════════════════════════════════════════════════════
// GLOBAL: CSV Export
// ══════════════════════════════════════════════════════
window.exportTableToCSV = function (tableId, filename) {
    const table = document.getElementById(tableId);
    if (!table) return;
    const rows = [...table.querySelectorAll('tr')];
    const csv  = rows.map(row =>
        [...row.querySelectorAll('th,td')]
            .map(cell => '"' + cell.innerText.replace(/"/g, '""').trim() + '"')
            .join(',')
    ).join('\n');
    const bom  = '\uFEFF';
    const blob = new Blob([bom + csv], { type: 'text/csv;charset=utf-8;' });
    const url  = URL.createObjectURL(blob);
    const a    = Object.assign(document.createElement('a'), { href: url, download: filename || 'exportacao.csv' });
    document.body.appendChild(a);
    a.click();
    document.body.removeChild(a);
    URL.revokeObjectURL(url);
};
</script>
