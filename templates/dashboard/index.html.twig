{% block extra_js %}
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.4/dist/chart.umd.min.js"></script>
<script>
Chart.defaults.font.family = "'DM Sans', sans-serif";
Chart.defaults.font.size   = 11;
Chart.defaults.color       = '#9399ad';

const trendLabels = {{ trendLabels|raw }};
const trendAvg    = {{ trendAvgValues|raw }};
const fmtD = d => { if(!d) return ''; const p=d.split('-'); return p[2]+'/'+p[1]; };

function buildChart(canvasId, labels, data) {
    const canvas = document.getElementById(canvasId);
    if (!canvas) return;
    const ctx  = canvas.getContext('2d');
    const grad = ctx.createLinearGradient(0, 0, 0, 200);
    grad.addColorStop(0, 'rgba(37,99,235,.18)');
    grad.addColorStop(1, 'rgba(37,99,235,0)');
    return new Chart(ctx, {
        type: 'line',
        data: {
            labels: labels.map(fmtD),
            datasets: [{
                data: data,
                borderColor: '#2563eb',
                backgroundColor: grad,
                borderWidth: 2.5,
                pointRadius: 3,
                pointBackgroundColor: '#2563eb',
                pointHoverRadius: 5,
                tension: 0.4,
                fill: true,
            }],
        },
        options: {
            responsive: true,
            maintainAspectRatio: false,
            plugins: {
                legend: { display: false },
                tooltip: {
                    backgroundColor: '#1a1d2e',
                    titleColor: '#e2e8f0',
                    bodyColor: '#9399ad',
                    borderColor: '#2d3251',
                    borderWidth: 1,
                    padding: 10,
                    callbacks: { label: c => ' R$ ' + c.parsed.y.toFixed(2).replace('.', ',') },
                },
            },
            scales: {
                x: { grid: { display: false }, ticks: { color: '#9399ad', maxRotation: 0, autoSkip: true, maxTicksLimit: 8 }, bounds: 'data' },
                y: { display: true, grid: { color: '#f0f2f8', drawBorder: false }, ticks: { color: '#9399ad', callback: v => 'R$ ' + v.toFixed(0), maxTicksLimit: 5 } },
            },
            layout: { padding: { right: 12 } },
        },
    });
}

buildChart('trendChart', trendLabels, trendAvg);

// ── Modal system ─────────────────────────────────────
(function () {
    let trendModalChart = null;

    function openModal(id) {
        if (!id) return;
        const modal = document.getElementById(id);
        if (!modal) return;
        modal.classList.add('is-open');
        document.body.classList.add('modal-open');

        // Inicializa chart do modal de tendência na primeira abertura
        if (id === 'modal-trend' && !trendModalChart) {
            setTimeout(() => {
                trendModalChart = buildChart('trendChartModal', trendLabels, trendAvg);
            }, 50);
        }
    }

    function closeModal(modal) {
        modal.classList.remove('is-open');
        if (!document.querySelector('.vg-modal-backdrop.is-open')) {
            document.body.classList.remove('modal-open');
        }
    }

    // Abre por data-modal em qualquer elemento
    document.addEventListener('click', e => {
        const trigger = e.target.closest('[data-modal]');
        if (!trigger) return;
        // Não propaga se clicou dentro de um modal aberto em elemento sem data-modal
        if (trigger.closest('.vg-modal-backdrop.is-open') && !trigger.dataset.modal) return;
        e.stopPropagation();
        openModal(trigger.dataset.modal);
    });

    // Fecha pelo ✕
    document.querySelectorAll('[data-close]').forEach(btn => {
        btn.addEventListener('click', e => {
            e.stopPropagation();
            closeModal(btn.closest('.vg-modal-backdrop'));
        });
    });

    // Fecha clicando no backdrop
    document.querySelectorAll('.vg-modal-backdrop').forEach(backdrop => {
        backdrop.addEventListener('click', e => {
            if (e.target === backdrop) closeModal(backdrop);
        });
    });

    // Esc
    document.addEventListener('keydown', e => {
        if (e.key === 'Escape') {
            document.querySelectorAll('.vg-modal-backdrop.is-open').forEach(m => closeModal(m));
        }
    });

    // Bloqueia scroll fora do modal body
    document.querySelectorAll('.vg-modal-backdrop').forEach(backdrop => {
        backdrop.addEventListener('wheel', e => {
            const body = backdrop.querySelector('.vg-modal-body');
            if (!body) return;
            if (body.contains(e.target) || body === e.target) return;
            e.preventDefault();
        }, { passive: false });
    });

    // Popovers — position fixed para escapar de qualquer overflow
    document.querySelectorAll('.vg-pop').forEach(pop => {
        const popover = pop.querySelector('.vg-popover');
        if (!popover) return;

        pop.addEventListener('mouseenter', () => {
            const r = pop.getBoundingClientRect();
            popover.style.position = 'fixed';
            popover.style.display  = 'block';
            popover.style.top      = (r.bottom + 8) + 'px';

            // Se sair da tela pela direita, abre à esquerda
            const rightEdge = window.innerWidth - r.right;
            if (rightEdge < 260) {
                popover.style.right = rightEdge + 'px';
                popover.style.left  = 'auto';
            } else {
                popover.style.left  = r.left + 'px';
                popover.style.right = 'auto';
            }
        });

        pop.addEventListener('mouseleave', () => {
            popover.style.display = 'none';
        });
    });

})();
</script>
{% endblock %}
