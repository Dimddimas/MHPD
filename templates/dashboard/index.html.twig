{% extends 'base.html.twig' %}

{% block title %}Visão Geral Estratégica{% endblock %}
{% block page_title %}Visão Geral Estratégica{% endblock %}
{% block page_subtitle %}Inteligência de preços · tempo real{% endblock %}

{% block extra_css %}
<style>
/* ═══════════════════════════════════════
   BASE
═══════════════════════════════════════ */
.vg-wrap { display:flex; flex-direction:column; gap:16px; }

/* ═══════════════════════════════════════
   KPI ROW
═══════════════════════════════════════ */
.kpi-row {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 12px;
}
@media(max-width:1300px){ .kpi-row { grid-template-columns: repeat(3,1fr); } }
@media(max-width:800px) { .kpi-row { grid-template-columns: 1fr 1fr; } }

.kpi-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: 18px 20px 16px;
    box-shadow: var(--shadow);
    display: flex;
    flex-direction: column;
    gap: 4px;
}
.kpi-label {
    font-size: 10px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: .07em;
    color: var(--text-muted);
}
.kpi-value-xl {
    font-size: 42px;
    font-weight: 700;
    color: var(--text-primary);
    line-height: 1.05;
    font-variant-numeric: tabular-nums;
}
.kpi-value-md {
    font-size: 20px;
    font-weight: 700;
    color: var(--text-primary);
    line-height: 1.25;
    margin-top: 4px;
}
.kpi-sub { font-size: 12px; color: var(--text-secondary); margin-top:2px; }
.kpi-sub-green { font-size: 12px; color: var(--green); font-weight:600; margin-top:2px; }
.kpi-badge-disp {
    display: inline-block;
    margin-top: 8px;
    background: #fef3c7;
    color: #b45309;
    font-size: 11px;
    font-weight: 700;
    padding: 3px 10px;
    border-radius: 20px;
    border: 1px solid #fde68a;
}

/* ═══════════════════════════════════════
   MAIN ROW
═══════════════════════════════════════ */
.main-row {
    display: grid;
    grid-template-columns: 1fr 360px;
    gap: 14px;
    align-items: start;
}
@media(max-width:1200px){ .main-row { grid-template-columns:1fr; } }

.sidebar-fixed {
    display: flex;
    flex-direction: column;
    gap: 14px;
    align-self: start;
}

.thermo-scroll {
    max-height: 460px;
    overflow-y: auto;
    overflow-x: hidden;
}

/* ═══════════════════════════════════════
   CARD
═══════════════════════════════════════ */
.vg-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow);
    overflow: hidden;
}
.vg-card-hd {
    padding: 12px 16px 10px;
    border-bottom: 1px solid var(--border);
    display: flex;
    align-items: center;
    justify-content: space-between;
}
.vg-card-title {
    font-size: 10.5px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: .07em;
    color: var(--text-secondary);
}
.vg-card-hint {
    font-size: 10px;
    color: var(--brand, #2563eb);
    font-weight: 600;
    cursor: pointer;
    opacity: 0;
    transition: opacity .15s;
}
.vg-card:hover .vg-card-hint { opacity: 1; }

/* ═══════════════════════════════════════
   TERMÔMETRO
═══════════════════════════════════════ */
.thermo-list { padding: 12px 18px 8px; display:flex; flex-direction:column; gap:0; }
.thermo-row {
    display: grid;
    grid-template-columns: 130px 1fr;
    align-items: center;
    gap: 12px;
    padding: 11px 0;
    border-bottom: 1px solid #f0f2f8;
    cursor: pointer;
    transition: background .12s;
    border-radius: 6px;
}
.thermo-row:hover { background: #f8f9fc; }
.thermo-row:last-child { border-bottom:none; }

.thermo-label-col {
    display: flex;
    flex-direction: column;
    gap: 2px;
}
.thermo-name {
    font-size: 13px;
    font-weight: 500;
    color: var(--text-primary);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
}
.thermo-min-lbl {
    font-size: 11px;
    font-weight: 700;
    color: var(--brand);
    font-variant-numeric: tabular-nums;
    cursor: help;
}

/* Barra */
.thermo-bar-wrap {
    position: relative;
    height: 44px;
    display: flex;
    align-items: center;
}
.thermo-track {
    position: absolute;
    left: 0; right: 0;
    height: 10px;
    background: #e8ecf5;
    border-radius: 5px;
}
.thermo-fill {
    position: absolute;
    height: 10px;
    border-radius: 5px;
    background: linear-gradient(to right, #3b82f6, #ef4444);
}
.thermo-avg-pin {
    position: absolute;
    width: 3px;
    height: 20px;
    background: #1e3a8a;
    border-radius: 2px;
    top: 50%;
    transform: translate(-50%, -50%);
}
.thermo-avg-lbl {
    position: absolute;
    bottom: calc(50% + 13px);
    font-size: 10px;
    font-weight: 600;
    color: #1e3a8a;
    transform: translateX(-50%);
    white-space: nowrap;
    pointer-events: none;
    background: rgba(255,255,255,.85);
    padding: 0 2px;
    border-radius: 3px;
}
.thermo-max-dot {
    width: 11px;
    height: 11px;
    background: #ef4444;
    border: 2px solid #fff;
    border-radius: 50%;
    box-shadow: 0 1px 3px rgba(0,0,0,.2);
    cursor: help;
}
.thermo-max-lbl {
    position: absolute;
    bottom: calc(50% + 13px);
    font-size: 10px;
    font-weight: 700;
    color: #dc2626;
    transform: translateX(-50%);
    white-space: nowrap;
    pointer-events: none;
    background: rgba(255,255,255,.85);
    padding: 0 2px;
    border-radius: 3px;
}
.thermo-bar-wrap .vg-pop {
    position: absolute;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 18px;
    height: 18px;
}

/* ═══════════════════════════════════════
   RANKING
═══════════════════════════════════════ */
.rank-table { width:100%; border-collapse:collapse; font-size:12px; }
.rank-table th {
    font-size:10px; font-weight:700; text-transform:uppercase;
    letter-spacing:.04em; color:var(--text-muted);
    padding:8px 12px; border-bottom:1px solid var(--border); text-align:left;
}
.rank-table th:not(:first-child) { text-align:center; }
.rank-table td { padding:8px 12px; border-bottom:1px solid #f0f2f8; }
.rank-table tr:last-child td { border-bottom:none; }
.rank-table td:not(:first-child) { text-align:center; font-variant-numeric:tabular-nums; }
.rank-table tr { cursor: pointer; transition: background .12s; }
.rank-table tr:hover td { background: #f8f9fc; }
.rank-score {
    background: var(--brand-light);
    color: var(--brand);
    font-weight:700; font-size:11px;
    padding:2px 8px; border-radius:10px; display:inline-block;
}

/* ═══════════════════════════════════════
   HEATMAP
═══════════════════════════════════════ */
.hm-table { width:100%; border-collapse:collapse; }
.hm-table th {
    font-size:12px; font-weight:700; text-transform:uppercase;
    letter-spacing:.04em; color:var(--text-muted);
    padding: 10px 16px;
    border-bottom: 1px solid var(--border);
    text-align: center;
    background: var(--surface);
    white-space: nowrap;
}
.hm-table th:first-child { text-align:left; min-width:160px; }
.hm-table td {
    padding: 0;
    border: 2px solid var(--bg);
    height: 50px;
    text-align: center;
    font-size: 11.5px;
    font-weight: 600;
    vertical-align: middle;
    transition: filter .15s;
    position: relative;
}
.hm-table td:first-child {
    padding: 0 16px;
    font-size: 13px;
    font-weight: 500;
    color: var(--text-primary);
    background: var(--surface);
    text-align: left;
    border-right: 1px solid var(--border);
    cursor: pointer;
}
.hm-table td:first-child:hover { background: #f8f9fc; }
.hm-table td:hover:not(:first-child) { filter: brightness(.93); cursor: pointer; }
.hm-cell-val { font-size: 11px; font-weight: 700; line-height: 1.3; }
.hm-cell-sub { font-size: 9.5px; opacity: .75; font-weight: 400; }
.hm-0  { background:#f0f2f8; color:var(--text-muted); }
.hm-g1 { background:#d1fae5; color:#065f46; }
.hm-g2 { background:#6ee7b7; color:#064e3b; }
.hm-g3 { background:#10b981; color:#fff; }
.hm-g4 { background:#047857; color:#fff; }
.hm-r1 { background:#fecaca; color:#991b1b; }
.hm-r2 { background:#f87171; color:#fff; }
.hm-r3 { background:#dc2626; color:#fff; }
.hm-y1 { background:#fef3c7; color:#92400e; }
.hm-y2 { background:#fde68a; color:#78350f; }
.hm-y3 { background:#f59e0b; color:#fff; }

/* ═══════════════════════════════════════
   KPI CLICKABLE
═══════════════════════════════════════ */
.kpi-clickable {
    cursor: pointer;
    transition: box-shadow .18s, transform .18s, border-color .18s;
    position: relative;
}
.kpi-clickable:hover {
    box-shadow: 0 4px 24px rgba(37,99,235,.10);
    border-color: var(--brand, #2563eb);
    transform: translateY(-1px);
}
.kpi-hint {
    font-size: 10px;
    color: var(--brand, #2563eb);
    opacity: 0;
    margin-top: 6px;
    font-weight: 600;
    letter-spacing: .04em;
    transition: opacity .15s;
}
.kpi-clickable:hover .kpi-hint { opacity: 1; }

/* ═══════════════════════════════════════
   MODAL BACKDROP
═══════════════════════════════════════ */
.vg-modal-backdrop {
    display: none;
    position: fixed !important;
    top: 0 !important; left: 0 !important;
    right: 0 !important; bottom: 0 !important;
    z-index: 9999 !important;
    background: rgba(10,12,28,.45);
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
    align-items: center;
    justify-content: center;
    padding: 20px;
}
.vg-modal-backdrop.is-open {
    display: flex;
    animation: backdropIn .2s ease;
    overflow: hidden;
}
@keyframes backdropIn { from { opacity:0; } to { opacity:1; } }
body.modal-open { overflow: hidden; }

/* ═══════════════════════════════════════
   MODAL
═══════════════════════════════════════ */
.vg-modal {
    background: var(--surface, #fff);
    border: 1px solid var(--border, #e2e8f0);
    border-radius: 16px;
    box-shadow: 0 24px 80px rgba(0,0,0,.22);
    width: 100%;
    max-width: 580px;
    max-height: calc(100vh - 80px);
    display: flex;
    flex-direction: column;
    overflow: hidden;
    animation: modalIn .22s cubic-bezier(.34,1.3,.64,1);
    position: relative;
    z-index: 1;
}
.vg-modal.vg-modal-wide { max-width: 720px; }
@keyframes modalIn {
    from { opacity:0; transform: scale(.96) translateY(8px); }
    to   { opacity:1; transform: scale(1)   translateY(0); }
}
.vg-modal-hd {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    padding: 22px 24px 18px;
    border-bottom: 1px solid var(--border);
    flex-shrink: 0;
}
.vg-modal-label {
    font-size: 10px; font-weight: 700; text-transform: uppercase;
    letter-spacing: .08em; color: var(--brand, #2563eb); margin-bottom: 4px;
}
.vg-modal-title { font-size: 18px; font-weight: 700; color: var(--text-primary); line-height: 1.2; }
.vg-modal-close {
    background: none; border: 1px solid var(--border); border-radius: 8px;
    width: 32px; height: 32px; cursor: pointer; color: var(--text-muted);
    font-size: 13px; display: flex; align-items: center; justify-content: center;
    flex-shrink: 0; transition: background .15s, color .15s; margin-left: 16px;
}
.vg-modal-close:hover { background: var(--border); color: var(--text-primary); }
.vg-modal-body {
    padding: 20px 24px 24px;
    overflow-y: auto;
    flex: 1;
    min-height: 0;
}
.vg-modal-stat-row {
    display: grid; grid-template-columns: repeat(3, 1fr); gap: 12px; margin-bottom: 4px;
}
.vg-modal-stat {
    background: var(--bg, #f8f9fc); border: 1px solid var(--border);
    border-radius: 10px; padding: 14px 16px; text-align: center;
}
.vg-modal-stat-val {
    font-size: 22px; font-weight: 700; color: var(--text-primary);
    font-variant-numeric: tabular-nums; line-height: 1.1;
}
.vg-modal-stat-lbl {
    font-size: 10px; color: var(--text-muted); margin-top: 4px;
    text-transform: uppercase; letter-spacing: .05em; font-weight: 600;
}
.vg-modal-divider { height: 1px; background: var(--border); margin: 18px 0 16px; }
.vg-modal-sub-title {
    font-size: 11px; font-weight: 700; text-transform: uppercase;
    letter-spacing: .06em; color: var(--text-muted); margin-bottom: 10px;
}
.vg-modal-note { font-size: 13px; color: var(--text-secondary); line-height: 1.6; margin: 0 0 4px; }
.vg-modal-highlight {
    background: linear-gradient(135deg, #eff6ff 0%, #f0fdf4 100%);
    border: 1px solid #bfdbfe; border-radius: 12px; padding: 18px 20px;
}
.vg-modal-highlight-name { font-size: 15px; font-weight: 700; color: var(--text-primary); margin-bottom: 6px; }
.vg-modal-highlight-range {
    font-size: 22px; font-weight: 700; color: var(--text-primary); font-variant-numeric: tabular-nums;
}
.vg-arrow { color: var(--text-muted); margin: 0 6px; font-weight: 400; }
.vg-modal-highlight-badge {
    display: inline-block; margin-top: 10px; background: #fef3c7; color: #b45309;
    font-size: 11px; font-weight: 700; padding: 3px 12px; border-radius: 20px; border: 1px solid #fde68a;
}
.vg-modal-table { width: 100%; border-collapse: collapse; font-size: 12.5px; }
.vg-modal-table th {
    font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: .05em;
    color: var(--text-muted); padding: 7px 10px; border-bottom: 1px solid var(--border);
    text-align: left; white-space: nowrap;
}
.vg-modal-table td {
    padding: 9px 10px; border-bottom: 1px solid #f0f2f8; color: var(--text-primary);
    font-variant-numeric: tabular-nums;
}
.vg-modal-table tr:last-child td { border-bottom: none; }
.vg-modal-table tr:hover td { background: var(--bg, #f8f9fc); }
.vg-disp-badge {
    display: inline-block; font-size: 11px; font-weight: 700; padding: 2px 9px; border-radius: 10px;
}
.disp-high { background: #fee2e2; color: #991b1b; }
.disp-mid  { background: #fef3c7; color: #92400e; }
.disp-low  { background: #d1fae5; color: #065f46; }

/* ── Scroll list ── */
.vg-modal-scroll-list {
    max-height: 280px;
    overflow-y: auto;
    scrollbar-width: thin;
    scrollbar-color: #d1d5e8 transparent;
}
.vg-modal-scroll-list::-webkit-scrollbar { width: 3px; }
.vg-modal-scroll-list::-webkit-scrollbar-track { background: transparent; }
.vg-modal-scroll-list::-webkit-scrollbar-thumb { background: #d1d5e8; border-radius: 99px; }
.vg-modal-list-row {
    display: flex; align-items: center; justify-content: space-between;
    padding: 9px 4px 9px 0; border-bottom: 1px solid #f0f2f8;
}
.vg-modal-list-row:last-child { border-bottom: none; }
.vg-modal-list-name { font-size: 13px; color: var(--text-primary); font-weight: 500; }
.vg-modal-list-val {
    font-size: 12px; font-weight: 700; color: var(--brand, #2563eb);
    background: var(--brand-light, #eff6ff); padding: 2px 10px;
    border-radius: 10px; white-space: nowrap; flex-shrink: 0;
}

/* ── Popover ── */
.vg-pop { position: relative; display: inline-flex; align-items: center; }
.vg-pop-trigger { cursor: help; }
.vg-popover {
    display: none;
    position: fixed;
    z-index: 99999;
    background: var(--surface, #fff);
    border: 1px solid var(--border, #e2e8f0);
    border-radius: 12px;
    box-shadow: 0 8px 32px rgba(0,0,0,.14);
    padding: 14px 16px;
    min-width: 240px;
    max-width: 320px;
    font-size: 12.5px;
    color: var(--text-primary, #111);
    pointer-events: none;
    animation: popIn .15s ease;
}
@keyframes popIn { from { opacity:0; transform:translateY(4px); } to { opacity:1; transform:translateY(0); } }
.vg-popover-title {
    font-size: 10px; font-weight: 700; text-transform: uppercase;
    letter-spacing: .06em; color: var(--text-muted, #9399ad); margin-bottom: 8px;
}
.vg-popover-row {
    display: flex; align-items: center; justify-content: space-between;
    padding: 5px 0; border-bottom: 1px solid #f0f2f8; font-size: 12px;
}
.vg-popover-row:last-child { border-bottom: none; }
.vg-popover-badge {
    font-size: 11px; font-weight: 700; color: var(--brand, #2563eb);
    background: var(--brand-light, #eff6ff); padding: 1px 8px; border-radius: 8px; white-space: nowrap;
}
</style>
{% endblock %}

{% block body %}
<div class="vg-wrap">

{# ══════════════════════════════════════════════════════
   KPI ROW
══════════════════════════════════════════════════════ #}
<div class="kpi-row">

    <div class="kpi-card kpi-clickable" data-modal="modal-labs">
        <div class="kpi-label">Laboratórios Ativos no Radar</div>
        <div class="kpi-value-xl">{{ kpi.labs_today|default(0) }}</div>
        <div class="kpi-sub">Redes monitoradas hoje</div>
        {% set delta = kpi.labs_delta|default(0) %}
        {% if delta > 0 %}
            <div class="kpi-sub-green">+{{ delta }} vs. semana anterior</div>
        {% elseif delta < 0 %}
            <div class="kpi-sub" style="color:#ef4444;font-weight:600">{{ delta }} vs. semana anterior</div>
        {% else %}
            <div class="kpi-sub">Estável vs. semana anterior</div>
        {% endif %}
        <div class="kpi-hint">Ver detalhes →</div>
    </div>

    <div class="kpi-card kpi-clickable" data-modal="modal-procedures">
        <div class="kpi-label">Procedimentos Monitorados</div>
        <div class="kpi-value-xl">{{ kpi.procedures_today|default(0) }}</div>
        <div class="kpi-sub">Procedimentos Estratégicos</div>
        <div class="kpi-sub" style="color:var(--text-muted)">Laboratoriais – Curitiba</div>
        <div class="kpi-hint">Ver detalhes →</div>
    </div>

    <div class="kpi-card kpi-clickable" data-modal="modal-dispersion">
        <div class="kpi-label">Maior Dispersão de Preço</div>
        <div class="kpi-value-md">
            {{ kpi.max_dispersion_name|default('—')|slice(0,22) }}{% if (kpi.max_dispersion_name|default('')|length) > 22 %}…{% endif %}
        </div>
        <div class="kpi-sub" style="font-variant-numeric:tabular-nums">
            {% if kpi.max_dispersion_min is defined and kpi.max_dispersion_min %}
                R$ {{ kpi.max_dispersion_min|number_format(2,',','.') }}
                → R$ {{ kpi.max_dispersion_max|number_format(2,',','.') }}
            {% endif %}
        </div>
        {% if kpi.max_dispersion_pct is defined and kpi.max_dispersion_pct %}
        <span class="kpi-badge-disp">Dispersão: {{ kpi.max_dispersion_pct|number_format(0) }}%</span>
        {% endif %}
        <div class="kpi-hint">Ver detalhes →</div>
    </div>

    <div class="kpi-card kpi-clickable" data-modal="modal-cheapest">
        <div class="kpi-label">Menor Preço do Dia</div>
        <div class="kpi-value-md" style="font-size:16px;margin-top:6px;color:var(--text-secondary)">
            {{ kpi.cheapest_name|default('—')|slice(0,20) }}
        </div>
        <div class="kpi-value-xl" style="font-size:36px">
            {% if kpi.cheapest_price is defined and kpi.cheapest_price %}
                R$ {{ kpi.cheapest_price|number_format(2,',','.') }}
            {% else %}—{% endif %}
        </div>
        <div class="kpi-hint">Ver detalhes →</div>
    </div>

    <div class="kpi-card kpi-clickable" data-modal="modal-arbitrage">
        <div class="kpi-label">Oportunidade de Arbitragem</div>
        <div class="kpi-sub" style="margin-top:8px;line-height:1.5;color:var(--text-secondary)">
            Diferença média entre menor e maior preço:
        </div>
        <div class="kpi-value-xl" style="font-size:36px;margin-top:4px">
            {% if kpi.max_dispersion_pct is defined and kpi.max_dispersion_pct %}
                +{{ kpi.max_dispersion_pct|number_format(0) }}%
            {% else %}—{% endif %}
        </div>
        <div class="kpi-hint">Ver detalhes →</div>
    </div>

</div>

{# ══════════════════════════════════════════════════════
   MAIN ROW — Termômetro + Sidebar
══════════════════════════════════════════════════════ #}
<div class="main-row">

    {# ── Termômetro ── #}
    <div class="vg-card">
        <div class="vg-card-hd">
            <div class="vg-card-title">Termômetro de Mercado</div>
            <span class="vg-card-hint" data-modal="modal-procedures">Ver todos →</span>
        </div>
        {% if thermoData is empty %}
        <div style="padding:40px;text-align:center;color:var(--text-muted)">
            <i class="bi bi-thermometer" style="font-size:28px"></i>
            <p>Nenhum dado coletado hoje ainda.</p>
        </div>
        {% else %}

        {% set globalMax = 1 %}
        {% set globalMin = 999999 %}
        {% for row in thermoData|slice(0,15) %}
            {% if row.max_price > globalMax %}{% set globalMax = row.max_price %}{% endif %}
            {% if row.min_price < globalMin %}{% set globalMin = row.min_price %}{% endif %}
        {% endfor %}
        {% set globalRange = globalMax - globalMin %}
        {% if globalRange < 1 %}{% set globalRange = 1 %}{% endif %}

        {% set margin = 3 %}
        {% set usable  = 100 - (margin * 2) %}

        <div class="thermo-scroll"><div class="thermo-list">
        {% for row in thermoData|slice(0,15) %}
            {% set minPct  = margin + ((row.min_price  - globalMin) / globalRange * usable)|round %}
            {% set avgPct  = margin + ((row.avg_price  - globalMin) / globalRange * usable)|round %}
            {% set maxPct  = margin + ((row.max_price  - globalMin) / globalRange * usable)|round %}
            {% set fillW   = maxPct - minPct %}
            {% set pid = row.procedure_id %}

            <div class="thermo-row" data-modal="modal-proc-{{ pid }}">
                <div class="thermo-label-col">
                    <div class="thermo-name" title="{{ row.name }}">
                        {{ row.name|slice(0,16) }}{% if row.name|length > 16 %}…{% endif %}
                    </div>
                    <span class="vg-pop">
                        <span class="vg-pop-trigger thermo-min-lbl">R$ {{ row.min_price|number_format(2,',','.') }}</span>
                        <span class="vg-popover">
                            <div class="vg-popover-title">Menor preço</div>
                            <div class="vg-popover-row">
                                <span>{{ procPriceDetails[pid].min_lab|default('—')|slice(0,26) }}</span>
                                <span class="vg-popover-badge">R$ {{ row.min_price|number_format(2,',','.') }}</span>
                            </div>
                        </span>
                    </span>
                </div>

                <div class="thermo-bar-wrap">
                    <div class="thermo-track"></div>
                    <div class="thermo-fill" style="left:{{ minPct }}%;width:{{ fillW > 1 ? fillW : 1 }}%"></div>
                    <span class="thermo-avg-lbl" style="left:{{ avgPct }}%">R$ {{ row.avg_price|number_format(2,',','.') }}</span>
                    <div class="thermo-avg-pin" style="left:{{ avgPct }}%"></div>
                    {% if (maxPct - avgPct) > 8 %}
                    <span class="thermo-max-lbl" style="left:{{ maxPct }}%">R$ {{ row.max_price|number_format(2,',','.') }}</span>
                    {% endif %}
                    <span class="vg-pop" style="left:{{ maxPct }}%;top:50%;transform:translate(-50%,-50%)">
                        <span class="vg-pop-trigger">
                            <div class="thermo-max-dot"></div>
                        </span>
                        <span class="vg-popover">
                            <div class="vg-popover-title">Maior preço</div>
                            <div class="vg-popover-row">
                                <span>{{ procPriceDetails[pid].max_lab|default('—')|slice(0,26) }}</span>
                                <span class="vg-popover-badge">R$ {{ row.max_price|number_format(2,',','.') }}</span>
                            </div>
                        </span>
                    </span>
                </div>
            </div>
        {% endfor %}
        </div></div>
        {% endif %}
    </div>

    {# ── Sidebar ── #}
    <div class="sidebar-fixed">

        <div class="vg-card">
            <div class="vg-card-hd">
                <div class="vg-card-title">Tendência Semanal</div>
                <span class="vg-card-hint" data-modal="modal-trend">Ver detalhes →</span>
            </div>
            <div style="padding:14px 16px 10px">
                <div style="height:200px">
                    <canvas id="trendChart"></canvas>
                </div>
                <div style="text-align:center;font-size:10px;color:var(--text-muted);margin-top:8px">
                    Últimos 7 dias
                </div>
            </div>
        </div>

        <div class="vg-card">
            <div class="vg-card-hd">
                <div class="vg-card-title">Ranking de Competitividade</div>
                <span class="vg-card-hint" data-modal="modal-ranking">Ver todos →</span>
            </div>
            {% if competitiveness is empty %}
            <div style="padding:20px;text-align:center;color:var(--text-muted);font-size:12px">Sem dados hoje.</div>
            {% else %}
            <table class="rank-table">
                <thead>
                    <tr>
                        <th>Unidade</th>
                        <th>Nº proc.<br>menor preço</th>
                        <th>Índice<br>Comp.</th>
                    </tr>
                </thead>
                <tbody>
                {% set maxLeads = competitiveness[0].qtd_liderancas %}
                {% for u in competitiveness|slice(0,6) %}
                <tr data-modal="modal-lab-{{ loop.index0 }}" style="cursor:pointer">
                    <td style="font-weight:500">
                        {{ u.facility_name|default('—')|slice(0,18) }}{% if (u.facility_name|default('')|length) > 18 %}…{% endif %}
                    </td>
                    <td>{{ u.qtd_liderancas }}</td>
                    <td>
                        {% set score = maxLeads > 0 ? (u.qtd_liderancas / maxLeads * 100)|round : 0 %}
                        <span class="rank-score">{{ score }}/100</span>
                    </td>
                </tr>
                {% endfor %}
                </tbody>
            </table>
            {% endif %}
        </div>

    </div>
</div>

{# ══════════════════════════════════════════════════════
   HEATMAP
══════════════════════════════════════════════════════ #}
<div class="vg-card">
    <div class="vg-card-hd">
        <div class="vg-card-title">Dispersão de Preços por Procedimento</div>
        <span class="vg-card-hint" data-modal="modal-dispersion">Ver ranking →</span>
    </div>
    <div style="overflow-x:auto">
    {% if heatmap is empty %}
    <div style="padding:30px;text-align:center;color:var(--text-muted)">Sem dados para o heatmap hoje.</div>
    {% else %}
    <table class="hm-table">
        <thead>
            <tr>
                <th>Procedimento</th>
                <th>Faixa R$ 0–10</th>
                <th>Faixa R$ 11–30</th>
                <th>Faixa R$ 31–50</th>
                <th>Faixa R$ 50+</th>
            </tr>
        </thead>
        <tbody>
        {% for procId, row in heatmap %}
            {% set procName = heatmapNames[procId]|default('—') %}
            {% set mn  = row.min|default(0) %}
            {% set av  = row.avg|default(0) %}
            {% set mx  = row.max|default(0) %}

            {% if av <= 10 %}{% set fa_class = 'hm-g4' %}{% set fa_val = 'R$ ' ~ mn|number_format(2,',','.') %}{% set fa_sub = 'mín' %}
            {% elseif mn <= 10 %}{% set fa_class = 'hm-g2' %}{% set fa_val = 'R$ ' ~ mn|number_format(2,',','.') %}{% set fa_sub = 'mín' %}
            {% else %}{% set fa_class = 'hm-0' %}{% set fa_val = '—' %}{% set fa_sub = '' %}{% endif %}

            {% if av > 10 and av <= 30 %}{% set fb_class = 'hm-y2' %}{% set fb_val = 'R$ ' ~ av|number_format(2,',','.') %}{% set fb_sub = 'média' %}
            {% elseif mn > 10 and mn <= 30 %}{% set fb_class = 'hm-y1' %}{% set fb_val = 'R$ ' ~ mn|number_format(2,',','.') %}{% set fb_sub = 'mín' %}
            {% elseif mx > 10 and mx <= 30 %}{% set fb_class = 'hm-y1' %}{% set fb_val = 'R$ ' ~ mx|number_format(2,',','.') %}{% set fb_sub = 'máx' %}
            {% else %}{% set fb_class = 'hm-0' %}{% set fb_val = '—' %}{% set fb_sub = '' %}{% endif %}

            {% if av > 30 and av <= 50 %}{% set fc_class = 'hm-r2' %}{% set fc_val = 'R$ ' ~ av|number_format(2,',','.') %}{% set fc_sub = 'média' %}
            {% elseif mx > 30 and mx <= 50 %}{% set fc_class = 'hm-r1' %}{% set fc_val = 'R$ ' ~ mx|number_format(2,',','.') %}{% set fc_sub = 'máx' %}
            {% else %}{% set fc_class = 'hm-0' %}{% set fc_val = '—' %}{% set fc_sub = '' %}{% endif %}

            {% if mx > 50 %}{% set fd_class = av > 50 ? 'hm-r3' : 'hm-r1' %}{% set fd_val = 'R$ ' ~ mx|number_format(2,',','.') %}{% set fd_sub = 'máx' %}
            {% else %}{% set fd_class = 'hm-0' %}{% set fd_val = '—' %}{% set fd_sub = '' %}{% endif %}

            <tr>
                <td title="{{ procName }}" data-modal="modal-proc-{{ procId }}">
                    {{ procName|slice(0,24) }}{% if procName|length > 24 %}…{% endif %}
                </td>
                <td class="{{ fa_class }}" data-modal="modal-proc-{{ procId }}" style="cursor:pointer">
                    {% if fa_val != '—' %}<div class="hm-cell-val">{{ fa_val }}</div>{% if fa_sub %}<div class="hm-cell-sub">{{ fa_sub }}</div>{% endif %}{% else %}—{% endif %}
                </td>
                <td class="{{ fb_class }}" data-modal="modal-proc-{{ procId }}" style="cursor:pointer">
                    {% if fb_val != '—' %}<div class="hm-cell-val">{{ fb_val }}</div>{% if fb_sub %}<div class="hm-cell-sub">{{ fb_sub }}</div>{% endif %}{% else %}—{% endif %}
                </td>
                <td class="{{ fc_class }}" data-modal="modal-proc-{{ fc_class != 'hm-0' ? procId : '' }}" style="cursor:pointer">
                    {% if fc_val != '—' %}<div class="hm-cell-val">{{ fc_val }}</div>{% if fc_sub %}<div class="hm-cell-sub">{{ fc_sub }}</div>{% endif %}{% else %}—{% endif %}
                </td>
                <td class="{{ fd_class }}" data-modal="modal-proc-{{ fd_class != 'hm-0' ? procId : '' }}" style="cursor:pointer">
                    {% if fd_val != '—' %}<div class="hm-cell-val">{{ fd_val }}</div>{% if fd_sub %}<div class="hm-cell-sub">{{ fd_sub }}</div>{% endif %}{% else %}—{% endif %}
                </td>
            </tr>
        {% endfor %}
        </tbody>
    </table>
    {% endif %}
    </div>
</div>

